// SETTINGS PAGE
// ════════════════════════════════════════════════════════════════
class _SettingsPage extends StatelessWidget {
  final _ShellState state;
  const _SettingsPage({required this.state});
  @override
  Widget build(BuildContext context) {
    final s = state;
    return SafeArea(
      child: SingleChildScrollView(
        physics: const BouncingScrollPhysics(),
        padding: const EdgeInsets.fromLTRB(16, 14, 16, 100),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            _SectionLabel(Lang.t('settings'), large: true),
            const SizedBox(height: 16),
            // ── Tier status card
            Container(
              padding: const EdgeInsets.all(14),
              margin: const EdgeInsets.only(bottom: 16),
              decoration: BoxDecoration(
                color: s._isPro ? C.cyan.withOpacity(0.08) : C.card,
                borderRadius: BorderRadius.circular(14),
                border: Border.all(
                    color: s._isPro ? C.cyan.withOpacity(0.4) : C.border),
              ),
              child: Row(
                children: [
                  Icon(
                      s._isPro
                          ? Icons.workspace_premium_rounded
                          : Icons.lock_open_rounded,
                      color: s._isPro ? C.cyan : C.tSec,
                      size: 22),
                  const SizedBox(width: 12),
                  Expanded(
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        Text(
                          s._isPro
                              ? (s._tier == Tier.rewarded
                                  ? '${Lang.t('proTierLabel')} — ${s._rewardedSecsLeft}${Lang.t('secLeft')}'
                                  : 'PRO — ${s._tier.name.toUpperCase()}')
                              : Lang.t('freeVersion'),
                          style: TextStyle(
                              color: s._isPro ? C.cyan : C.tSec,
                              fontSize: 13,
                              fontWeight: FontWeight.w700),
                        ),
                        Text(
                            s._isPro
                                ? Lang.t('allFeaturesActive')
                                : Lang.t('someFeaturesLocked'),
                            style:
                                const TextStyle(color: C.tDim, fontSize: 10)),
                      ],
                    ),
                  ),
                  if (!s._isPro)
                    TextButton(
                        onPressed: () => s.navigateTo(1),
                        child: Text(Lang.t('upgradeArrow'),
                            style:
                                const TextStyle(color: C.cyan, fontSize: 12))),
                ],
              ),
            ),
            // ── Language selector
            _SettingsGroup(
              title: Lang.t('language'),
              children: [
                Padding(
                  padding: const EdgeInsets.symmetric(vertical: 4),
                  child: Row(
                    children: [
                      const Icon(Icons.language_rounded,
                          color: C.tSec, size: 18),
                      const SizedBox(width: 10),
                      Expanded(
                          child: Text(Lang.t('languageSub'),
                              style: const TextStyle(
                                  color: C.tPrim, fontSize: 13))),
                      _LangToggle(state: s),
                    ],
                  ),
                ),
              ],
            ),
            const SizedBox(height: 16),
            // ── Detection thresholds
            _SettingsGroup(
              title: Lang.t('detectionThresholds'),
              children: [
                if (!s._isPro)
                  _LockedFeature(
                    label: Lang.t('lockedThresholds'),
                    onUpgrade: () => s.navigateTo(1),
                  )
                else ...[
                  _SliderRow(
                    label: Lang.t('sensitivity'),
                    value: s._sens,
                    min: 1.0,
                    max: 30.0,
                    unit: '×',
                    onChanged: (v) {
                      s.setState(() => s._sens = v);
                      s._savePrefs();
                    },
                  ),
                  _SliderRow(
                    label: Lang.t('alertThreshold'),
                    value: s._alertT,
                    min: 5.0,
                    max: 80.0,
                    unit: '',
                    hint: Lang.t('alertHint'),
                    onChanged: (v) {
                      s.setState(() => s._alertT = v);
                      s._savePrefs();
                    },
                  ),
                  _SliderRow(
                    label: Lang.t('strongThreshold'),
                    value: s._strongT,
                    min: 30.0,
                    max: 150.0,
                    unit: '',
                    hint: Lang.t('strongHint'),
                    onChanged: (v) {
                      s.setState(() => s._strongT = v);
                      s._savePrefs();
                    },
                  ),
                ],
              ],
            ),
            const SizedBox(height: 16),
            // ── Audio settings
            _SettingsGroup(
              title: Lang.t('audioSettings'),
              children: [
                _SwitchRow(
                  label: Lang.t('audioAlerts'),
                  icon: Icons.volume_up_rounded,
                  value: s._sndOn,
                  onChanged: (v) {
                    s.setState(() => s._sndOn = v);
                    if (!v) {
                      s._audio.setVolume(0.0).catchError((_) {});
                      s._beeping = false;
                      s._audio.stop().catchError((_) {});
                    }
                    s._savePrefs();
                  },
                ),
                if (!s._isPro)
                  _LockedFeature(
                    label: Lang.t('lockedAudioSens'),
                    onUpgrade: () => s.navigateTo(1),
                  )
                else
                  _SliderRow(
                    label: Lang.t('volume'),
                    value: s._audioVol,
                    min: 0.05,
                    max: 1.0,
                    unit: '',
                    color: C.orange,
                    onChanged: (v) {
                      s.setState(() => s._audioVol = v);
                      if (s._sndOn && s._beeping) {
                        s._audio.setVolume(v).catchError((_) {});
                      }
                      s._savePrefs();
                    },
                  ),
              ],
            ),
            const SizedBox(height: 16),
            // ── Feedback
            _SettingsGroup(
              title: Lang.t('feedback'),
              children: [
                _SwitchRow(
                  label: Lang.t('vibrationAlerts'),
                  icon: Icons.vibration_rounded,
                  value: s._vibOn,
                  onChanged: (v) {
                    s.setState(() => s._vibOn = v);
                    s._savePrefs();
                  },
                ),
                _SwitchRow(
                  label: Lang.t('autoCalibrate'),
                  icon: Icons.autorenew_rounded,
                  value: s._autoC,
                  onChanged: (v) {
                    s.setState(() => s._autoC = v);
                    s._savePrefs();
                  },
                ),
              ],
            ),
            const SizedBox(height: 16),
            // ── App info
            _SettingsGroup(
              title: Lang.t('app'),
              children: [
                _InfoRow(Lang.t('appVersion'), '5.0.0'),
                _InfoRow(
                    Lang.t('appStatus'),
                    s._tier == Tier.free
                        ? Lang.t('appFree')
                        : s._tier == Tier.rewarded
                            ? Lang.t('proTrialShort')
                            : '⭐ ${s._tier.name.toUpperCase()}'),
                _InfoRow(Lang.t('appTotalSamples'), '${s._totalSamples}'),
              ],
            ),
          ],
        ),
      ),
    );
  }
}

