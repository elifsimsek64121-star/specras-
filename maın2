class _NavBar extends StatelessWidget {
  final int tab;
  final int cartCount;
  final bool isPro;
  final ValueChanged<int> onTap;
  const _NavBar({
    required this.tab,
    required this.cartCount,
    required this.isPro,
    required this.onTap,
  });

  @override
  Widget build(BuildContext context) {
    final items = [
      (Icons.radar_rounded, Lang.t('navScan')),
      (Icons.shopping_bag_rounded, Lang.t('navShop')),
      (Icons.analytics_rounded, Lang.t('navAnalytics')),
      (Icons.settings_rounded, Lang.t('navSettings')),
    ];
    return Container(
      decoration: BoxDecoration(
        color: C.surface.withOpacity(0.95),
        border: const Border(top: BorderSide(color: C.border)),
      ),
      padding: const EdgeInsets.symmetric(vertical: 8),
      child: Row(
