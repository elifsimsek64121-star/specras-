// ════════════════════════════════════════════════════════════════
class _AnalyticsPage extends StatelessWidget {
  final _ShellState state;
  const _AnalyticsPage({required this.state});
  @override
  Widget build(BuildContext context) {
    final s = state;
    final dur = s._sessStart != null
        ? DateTime.now().difference(s._sessStart!)
        : Duration.zero;
    final durStr =
        '${dur.inMinutes}:${(dur.inSeconds % 60).toString().padLeft(2, '0')}';
    double avg = 0.0, peak = 0.0;
    if (s._readings.isNotEmpty) {
      avg = s._readings.map((r) => r.signal).reduce((a, b) => a + b) /
          s._readings.length;
      peak = s._readings.map((r) => r.signal).reduce((a, b) => a > b ? a : b);
    }
    final secs = s._sessStart != null
        ? DateTime.now().difference(s._sessStart!).inSeconds
        : 0;
    final rate =
        (secs > 0) ? '${(s._totalSamples / secs).toStringAsFixed(0)}/s' : '—';

    return SafeArea(
      child: SingleChildScrollView(
        physics: const BouncingScrollPhysics(),
        padding: const EdgeInsets.fromLTRB(16, 14, 16, 100),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            _SectionLabel(Lang.t('sessionAnalysis'), large: true),
            const SizedBox(height: 16),
            GridView.count(
              crossAxisCount: 2,
              shrinkWrap: true,
              physics: const NeverScrollableScrollPhysics(),
              crossAxisSpacing: 10,
              mainAxisSpacing: 10,
              childAspectRatio: 1.75,
              children: [
                _StatCard(Lang.t('sessionDuration'), durStr, C.cyan,
                    Icons.timer_rounded),
                _StatCard(Lang.t('detections'), '${s._totalDet}', C.red,
                    Icons.warning_rounded),
                _StatCard(Lang.t('readings'), '${s._readings.length}', C.green,
                    Icons.data_usage_rounded),
                _StatCard(Lang.t('avgSignal'), avg.toStringAsFixed(1), C.orange,
                    Icons.show_chart_rounded),
                _StatCard(Lang.t('peakSignal'), peak.toStringAsFixed(1),
                    C.purple, Icons.trending_up_rounded),
                _StatCard(
                    Lang.t('samplesPerSec'), rate, C.tSec, Icons.speed_rounded),
              ],
            ),
            const SizedBox(height: 24),
            if (!s._isPro)
              _ProGate(
                icon: Icons.download_rounded,
                title: Lang.t('csvExportTitle'),
                subtitle: Lang.t('csvExportSub'),
                onUpgrade: () => s.navigateTo(1),
              ),
            const SizedBox(height: 16),
            _SectionLabel(Lang.t('detectionLog')),
            const SizedBox(height: 10),
            if (s._detections.isEmpty)
              Center(
                child: Padding(
                  padding: const EdgeInsets.symmetric(vertical: 40),
                  child: Column(
                    children: [
                      const Icon(Icons.radar_rounded, color: C.tDim, size: 40),
                      const SizedBox(height: 10),
                      Text(
                          s._calDone
                              ? Lang.t('noDetectionsYet')
                              : Lang.t('calibratingDots'),
                          style: const TextStyle(color: C.tSec, fontSize: 13)),
                    ],
                  ),
                ),
              )
            else
              ...s._detections.reversed.take(50).map((d) => _DetTile(d: d)),
          ],
        ),
      ),
    );
  }
}

