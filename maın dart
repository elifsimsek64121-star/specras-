class _WavePainter extends CustomPainter {
  final List<double> hist;
  final int head;
  final double base, alert, noise, sens;
  final Color col;

  const _WavePainter({
    required this.hist,
    required this.head,
    required this.base,
    required this.col,
    required this.alert,
    required this.noise,
    required this.sens,
  });

  @override
  void paint(Canvas canvas, Size sz) {
    // Grid lines
    final grid = Paint()
      ..color = C.border.withOpacity(0.35)
      ..strokeWidth = 0.5;
    for (int i = 1; i < 4; i++) {
      final y = sz.height * i / 4;
      canvas.drawLine(Offset(0, y), Offset(sz.width, y), grid);
    }
    // Baseline
    canvas.drawLine(
      Offset(0, sz.height * 0.5),
      Offset(sz.width, sz.height * 0.5),
      Paint()
        ..color = Colors.white.withOpacity(0.06)
        ..strokeWidth = 1,
    );

    // Alert threshold line
    final alertY =
        sz.height * 0.5 - (alert / (noise * sens * 1.2 + 1)) * sz.height * 0.4;
    canvas.drawLine(
      Offset(0, alertY),
      Offset(sz.width, alertY),
      Paint()
        ..color = C.orange.withOpacity(0.3)
        ..strokeWidth = 0.8
        ..style = PaintingStyle.stroke
        ..strokeCap = StrokeCap.round,
    );

    if (base == 0) return;
    final dx = sz.width / (hist.length - 1);
    final scale = sz.height * 0.42 / max(noise * sens * 1.2, 5);

    double yAt(int i) {
      final idx = (head - 1 - i + hist.length) % hist.length;
      final v = hist[idx];
      if (v == 0) return sz.height * 0.5;
      return (sz.height * 0.5 - (v - base) * scale).clamp(2.0, sz.height - 2.0);
    }

    // Fill
    final fill = Path()..moveTo(sz.width, sz.height * 0.5);
    for (int i = 0; i < hist.length; i++) {
      fill.lineTo(sz.width - i * dx, yAt(i));
    }
    fill
      ..lineTo(0, sz.height * 0.5)
      ..close();
    canvas.drawPath(
        fill,
        Paint()
          ..color = col.withOpacity(0.07)
          ..style = PaintingStyle.fill);

    // Line
    final line = Path()..moveTo(sz.width, yAt(0));
    for (int i = 1; i < hist.length; i++) {
      line.lineTo(sz.width - i * dx, yAt(i));
    }
    canvas.drawPath(
        line,
        Paint()
          ..color = col
          ..strokeWidth = 2.0
          ..style = PaintingStyle.stroke
          ..strokeCap = StrokeCap.round
          ..strokeJoin = StrokeJoin.round);
  }

  @override
  bool shouldRepaint(_WavePainter o) =>
      o.head != head || o.col != col || o.base != base;
}

