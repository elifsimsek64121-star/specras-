class MagReading {
  final DateTime ts;
  final double x, y, z, magnitude, fieldStrength;
  MagReading(
      {required this.ts,
      required this.x,
      required this.y,
      required this.z,
      required this.magnitude,
      required this.fieldStrength});

  Map<String, dynamic> toJson() => {
        'ts': ts.toIso8601String(),
        'x': x,
        'y': y,
        'z': z,
        'mag': magnitude,
        'fs': fieldStrength,
      };
}

class Detection {
  final DateTime ts;
  final String type; // ferrous | nonferrous | gold | unknown
  final double confidence;
  final double signal;
  final String label;
  final Color color;

  Detection(
      {required this.ts,
      required this.type,
      required this.confidence,
      required this.signal,
      required this.label,
      required this.color});
}

class BtSensorData {
  final double magnitude;
  final double signal;
  final String raw;
  BtSensorData(
      {required this.magnitude, required this.signal, required this.raw});
}

