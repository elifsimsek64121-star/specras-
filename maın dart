class _DebugPage extends StatefulWidget {
  final _ShellState s;
  const _DebugPage({required this.s});

  @override
  State<_DebugPage> createState() => _DebugPageState();
}

class _DebugPageState extends State<_DebugPage> {
  @override
  Widget build(BuildContext ctx) {
    final logs = Log.all;

    return SafeArea(
      child: Column(children: [
        Padding(
          padding: const EdgeInsets.fromLTRB(16, 12, 16, 8),
          child: Column(children: [
            const _Lbl(t: 'DEBUG CONSOLE', big: true),
            const SizedBox(height: 10),
            Row(children: [
              Expanded(
                  child: _DbgBtn(
                      lbl: 'Clear',
                      ic: Icons.delete_rounded,
                      col: C.red,
                      tap: () {
                        Log.clear();
                        setState(() {});
                      })),
              const SizedBox(width: 10),
              Expanded(
                  child: _DbgBtn(
                      lbl: 'Refresh',
                      ic: Icons.refresh_rounded,
                      col: C.cyan,
                      tap: () => setState(() {}))),
              const SizedBox(width: 10),
              Expanded(
                  child: _DbgBtn(
                      lbl: 'IAP Info',
                      ic: Icons.store_rounded,
                      col: C.gold,
                      tap: () {
                        Log.i('IAP ready=${widget.s._iapReady}');
                        Log.i(
                            'Products: ${widget.s._products.map((p) => "${p.id}:${p.price}").join(",")}');
                        Log.i('Tier: ${widget.s._tier.name}');
                        Log.i(
                            'Baseline: ${widget.s._baseline.toStringAsFixed(3)}');
                        Log.i(
                            'NoiseFloor: ${widget.s._noiseFloor.toStringAsFixed(3)}');
                        setState(() {});
                      })),
            ]),
          ]),
        ),
        Container(height: 1, color: C.border),
        Expanded(
          child: logs.isEmpty
              ? const Center(
                  child: Text('No logs', style: TextStyle(color: C.tDim)))
              : ListView.builder(
                  reverse: true,
                  padding: const EdgeInsets.fromLTRB(16, 8, 16, 16),
                  itemCount: logs.length,
                  itemBuilder: (_, i) {
                    final log = logs[logs.length - 1 - i];
                    Color col = C.tSec;
                    if (log.contains('❌'))
                      col = C.red;
                    else if (log.contains('✅'))
                      col = C.green;
                    else if (log.contains('🔴'))
                      col = C.orange;
                    else if (log.contains('⚠️'))
                      col = C.orange;
                    else if (log.contains('🛒')) col = C.gold;
                    return Text(log,
                        style: TextStyle(
                          fontSize: 9.5,
                          color: col,
                          fontFamily: C.mono,
                          height: 1.55,
                        ));
                  },
                ),
        ),
      ]),
    );
  }
}

