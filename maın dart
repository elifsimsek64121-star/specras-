class _MetalBreakdown extends StatelessWidget {
  final int gold, ferrous, nonFerrous, total;
  final bool isPro;
  const _MetalBreakdown(
      {required this.gold,
      required this.ferrous,
      required this.nonFerrous,
      required this.total,
      required this.isPro});

  @override
  Widget build(BuildContext context) {
    final items = [
      if (isPro) ('ALTIN', gold, AppColors.gold),
      ('DEMİR', ferrous, AppColors.red),
      ('METAL', nonFerrous, AppColors.orange),
    ];
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: AppColors.card,
        borderRadius: BorderRadius.circular(12),
        border: Border.all(color: AppColors.border),
      ),
      child: Column(
          children: items.map((it) {
        final (label, count, col) = it;
        final pct = total > 0 ? count / total : 0.0;
        return Padding(
          padding: const EdgeInsets.only(bottom: 12),
          child: Column(children: [
            Row(mainAxisAlignment: MainAxisAlignment.spaceBetween, children: [
              Text(label,
                  style: TextStyle(
                    color: col,
                    fontSize: 11,
                    fontWeight: FontWeight.w700,
                    letterSpacing: 1,
                  )),
              Text('$count tane  (${(pct * 100).toStringAsFixed(0)}%)',
                  style:
                      const TextStyle(color: AppColors.textSec, fontSize: 11)),
            ]),
            const SizedBox(height: 6),
            ClipRRect(
              borderRadius: BorderRadius.circular(4),
              child: LinearProgressIndicator(
                value: pct,
                minHeight: 5,
                backgroundColor: AppColors.border,
                valueColor: AlwaysStoppedAnimation<Color>(col),
              ),
            ),
          ]),
        );
      }).toList()),
    );
  }
}

