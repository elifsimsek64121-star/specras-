class MagReading {
  final DateTime ts;
  final double x, y, z, raw, signal;

  MagReading({
    required this.ts,
    required this.x,
    required this.y,
    required this.z,
    required this.raw,
    required this.signal,
  });

  static String toCsv(List<MagReading> list) {
    final sb = StringBuffer('timestamp,x_uT,y_uT,z_uT,magnitude_uT,signal\n');
    for (final r in list) {
      sb.writeln(
        '${r.ts.toIso8601String()},'
        '${r.x.toStringAsFixed(4)},'
        '${r.y.toStringAsFixed(4)},'
        '${r.z.toStringAsFixed(4)},'
        '${r.raw.toStringAsFixed(4)},'
        '${r.signal.toStringAsFixed(4)}',
      );
    }
    return sb.toString();
  }
}

class DetectionEvent {
  final DateTime ts;
  final String type;
  final double conf, signal;
  final String label;
  final Color color;
  final IconData icon;

  DetectionEvent({
    required this.ts,
    required this.type,
    required this.conf,
    required this.signal,
    required this.label,
    required this.color,
    required this.icon,
  });
}

