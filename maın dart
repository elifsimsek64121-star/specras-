class AppLog {
  static final _logs = <String>[];
  static void log(String m) {
    final t = DateFormat('HH:mm:ss.SSS').format(DateTime.now());
    final msg = '[$t] $m';
    _logs.add(msg);
    debugPrint(msg);
    if (_logs.length > 1500) _logs.removeAt(0);
  }

  static List<String> get all => List.from(_logs);
  static void clear() => _logs.clear();
}

