// ──────────────────────────────────────────────
// ANALYTICS PAGE
// ──────────────────────────────────────────────
class _AnalyticsPage extends StatelessWidget {
  final _ShellState s;
  const _AnalyticsPage({required this.s});

  @override
  Widget build(BuildContext ctx) {
    final dur = s._sessStart != null
        ? DateTime.now().difference(s._sessStart!)
        : Duration.zero;
    final durStr =
        '${dur.inMinutes}:${(dur.inSeconds % 60).toString().padLeft(2, '0')}';

    final avg = s._readings.isEmpty
        ? 0.0
        : s._readings.map((r) => r.signal).reduce((a, b) => a + b) /
            s._readings.length;
    final peak = s._readings.isEmpty
        ? 0.0
        : s._readings.map((r) => r.signal).reduce(max);

    final gold = s._detections.where((d) => d.type == 'gold').length;
    final ferr = s._detections.where((d) => d.type == 'ferrous').length;
    final nonf = s._detections.where((d) => d.type == 'nonferrous').length;

    return SafeArea(
      child: SingleChildScrollView(
        physics: const BouncingScrollPhysics(),
        padding: const EdgeInsets.fromLTRB(16, 12, 16, 100),
        child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
          const _Lbl(t: 'SESSION ANALYTICS', big: true),
          const SizedBox(height: 16),
          GridView.count(
            crossAxisCount: 2,
            shrinkWrap: true,
            physics: const NeverScrollableScrollPhysics(),
            crossAxisSpacing: 10,
            mainAxisSpacing: 10,
            childAspectRatio: 1.7,
            children: [
              _StatCard('Session Time', durStr, C.cyan, Icons.timer_rounded),
              _StatCard(
                  'Detections', '${s._totalDet}', C.red, Icons.warning_rounded),
              _StatCard('Readings', '${s._readings.length}', C.green,
                  Icons.data_usage_rounded),
              _StatCard('Avg Signal', '${avg.toStringAsFixed(1)}', C.orange,
                  Icons.show_chart_rounded),
              _StatCard('Peak Signal', '${peak.toStringAsFixed(1)}', C.purple,
                  Icons.trending_up_rounded),
              _StatCard('Samples/sec', _samplesPerSec(s), C.tSec,
                  Icons.speed_rounded),
            ],
          ),
          const SizedBox(height: 22),
          const _Lbl(t: 'METAL TYPE BREAKDOWN'),
          const SizedBox(height: 10),
          _BreakdownCard(
              gold: gold,
              ferrous: ferr,
              nonFerrous: nonf,
              total: s._totalDet,
              isPro: s._tier == Tier.pro),
          const SizedBox(height: 22),
          _Lbl(t: 'DETECTION LOG (${s._detections.length})'),
          const SizedBox(height: 10),
          if (s._detections.isEmpty)
            Center(
                child: Padding(
              padding: const EdgeInsets.symmetric(vertical: 40),
              child: Column(children: [
                const Icon(Icons.radar_rounded, color: C.tDim, size: 40),
                const SizedBox(height: 10),
                Text(
                  s._calDone ? 'No detections yet' : 'Calibrating…',
                  style: const TextStyle(color: C.tSec, fontSize: 13),
                ),
              ]),
            ))
          else
            ...s._detections.reversed.take(50).map((d) => _DetTile(d: d)),
        ]),
      ),
    );
  }

  String _samplesPerSec(_ShellState s) {
    if (s._sessStart == null || s._totalSamples == 0) return '—';
    final secs = DateTime.now().difference(s._sessStart!).inSeconds;
    if (secs == 0) return '—';
    return '${(s._totalSamples / secs).toStringAsFixed(0)}/s';
  }
}

