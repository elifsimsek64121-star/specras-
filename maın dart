class _WaveformPainter extends CustomPainter {
  final List<double> history;
  final int head;
  final double baseline;
  final Color color;
  const _WaveformPainter(
      {required this.history,
      required this.head,
      required this.baseline,
      required this.color});

  @override
  void paint(Canvas canvas, Size size) {
    // Grid lines
    final gridPaint = Paint()
      ..color = AppColors.border.withOpacity(0.4)
      ..strokeWidth = 0.5;
    for (int i = 1; i < 4; i++) {
      final y = size.height * i / 4;
      canvas.drawLine(Offset(0, y), Offset(size.width, y), gridPaint);
    }

    // Baseline
    canvas.drawLine(
      Offset(0, size.height / 2),
      Offset(size.width, size.height / 2),
      Paint()
        ..color = Colors.white.withOpacity(0.08)
        ..strokeWidth = 1,
    );

    // Fill
    final fillPath = Path();
    final dx = size.width / (history.length - 1);
    fillPath.moveTo(size.width, size.height / 2);
    for (int i = 0; i < history.length; i++) {
      final idx = (head - 1 - i + history.length) % history.length;
      final dev = (history[idx] - baseline).abs() * 8.0;
      final y = (size.height / 2 - dev).clamp(2.0, size.height - 2.0);
      fillPath.lineTo(size.width - i * dx, y);
    }
    fillPath.lineTo(0, size.height / 2);
    fillPath.close();
    canvas.drawPath(
        fillPath,
        Paint()
          ..color = color.withOpacity(0.08)
          ..style = PaintingStyle.fill);

    // Line
    final linePath = Path();
    linePath.moveTo(size.width, size.height / 2);
    for (int i = 0; i < history.length; i++) {
      final idx = (head - 1 - i + history.length) % history.length;
      final dev = (history[idx] - baseline).abs() * 8.0;
      final y = (size.height / 2 - dev).clamp(2.0, size.height - 2.0);
      linePath.lineTo(size.width - i * dx, y);
    }
    canvas.drawPath(
        linePath,
        Paint()
          ..color = color
          ..strokeWidth = 1.8
          ..style = PaintingStyle.stroke
          ..strokeCap = StrokeCap.round
          ..strokeJoin = StrokeJoin.round);
  }

  @override
  bool shouldRepaint(_WaveformPainter o) => o.head != head || o.color != color;
}

