  static final _buf = <String>[];

  static void i(String m) {
    final s = '[${DateFormat('HH:mm:ss.SSS').format(DateTime.now())}] $m';
    _buf.add(s);
    debugPrint(s);
    if (_buf.length > 2000) _buf.removeAt(0);
