class _RadarPainter extends CustomPainter {
  final double signal, scanAngle, ripple, pulse;
  final Color sigColor;
  final bool detected;
  final List<double> hist;
  final int hIdx;

  const _RadarPainter({
    required this.signal,
    required this.sigColor,
    required this.scanAngle,
    required this.ripple,
    required this.detected,
    required this.pulse,
    required this.hist,
    required this.hIdx,
  });

  @override
  void paint(Canvas canvas, Size size) {
    final cx = size.width / 2, cy = size.height / 2;
    final maxR = size.width / 2 - 8;

    for (final frac in [0.33, 0.66, 1.0]) {
      canvas.drawCircle(
        Offset(cx, cy),
        maxR * frac,
        Paint()
          ..color = C.border.withOpacity(detected ? 0.5 : 0.25)
          ..style = PaintingStyle.stroke
          ..strokeWidth = 0.8,
      );
    }

    final crossPaint = Paint()
      ..color = C.border.withOpacity(0.2)
      ..strokeWidth = 0.6;
    canvas.drawLine(Offset(cx, cy - maxR), Offset(cx, cy + maxR), crossPaint);
    canvas.drawLine(Offset(cx - maxR, cy), Offset(cx + maxR, cy), crossPaint);

    canvas.drawCircle(
      Offset(cx, cy),
      maxR,
      Paint()
        ..shader = SweepGradient(
          startAngle: scanAngle - 1.2,
          endAngle: scanAngle,
          colors: [
            sigColor.withOpacity(0.0),
            sigColor.withOpacity(detected ? 0.22 : 0.1)
          ],
          tileMode: TileMode.clamp,
        ).createShader(Rect.fromCircle(center: Offset(cx, cy), radius: maxR))
        ..style = PaintingStyle.fill,
    );

    canvas.drawLine(
      Offset(cx, cy),
      Offset(cx + cos(scanAngle) * maxR, cy + sin(scanAngle) * maxR),
      Paint()
        ..color = sigColor.withOpacity(detected ? 0.8 : 0.4)
        ..strokeWidth = 1.5,
    );

    if (detected) {
      for (int i = 1; i <= 3; i++) {
        canvas.drawCircle(
          Offset(cx, cy),
          maxR * (0.3 + i * 0.2) * ripple,
          Paint()
            ..color = sigColor.withOpacity(0.5 * (1 - i * 0.25))
            ..style = PaintingStyle.stroke
            ..strokeWidth = 2.0,
        );
      }
    }
  }

  @override
  bool shouldRepaint(_RadarPainter old) => true;
}

