// ══════════════════════════════════════════════════════════════
// SHOPPING CART
// ══════════════════════════════════════════════════════════════
class CartItem {
  final String id, title, description, duration, originalPrice;
  final double price;
  final int discount;
  CartItem({
    required this.id,
    required this.title,
    required this.description,
    required this.price,
    required this.duration,
    required this.originalPrice,
    required this.discount,
  });
}

class ShoppingCart extends ChangeNotifier {
  final List<CartItem> _items = [];
  List<CartItem> get items => List.from(_items);
  int get itemCount => _items.length;
  double get totalPrice => _items.fold(0.0, (s, i) => s + i.price);
  bool hasItem(String id) => _items.any((i) => i.id == id);

  void addItem(CartItem item) {
    if (hasItem(item.id)) return;
    _items.add(item);
    notifyListeners();
  }

  void removeItem(String id) {
    _items.removeWhere((i) => i.id == id);
    notifyListeners();
  }

  void clear() {
    _items.clear();
    notifyListeners();
  }
}

// ══════════════════════════════════════════════════════════════
// AD MANAGER
// ══════════════════════════════════════════════════════════════
class AdManager {
  static final AdManager instance = AdManager._();
  AdManager._();

  BannerAd? bannerAd;
  InterstitialAd? interstitialAd;
  RewardedAd? rewardedAd;
  bool bannerLoaded = false;

  final _req = const AdRequest(
    keywords: ['metal detector', 'treasure hunting', 'outdoor'],
  );

  void loadBanner() {
    bannerAd?.dispose();
    bannerLoaded = false;
    BannerAd(
      adUnitId: AdIds.bannerId,
      size: AdSize.banner,
      request: _req,
      listener: BannerAdListener(
        onAdLoaded: (ad) {
          bannerAd = ad as BannerAd;
          bannerLoaded = true;
          Log.i('Banner loaded');
        },
        onAdFailedToLoad: (ad, err) {
          ad.dispose();
          Log.i('Banner error: ${err.code}');
          Future.delayed(const Duration(seconds: 30), loadBanner);
        },
      ),
    ).load();
  }

  void loadInterstitial() {
    if (interstitialAd != null) return;
    InterstitialAd.load(
      adUnitId: AdIds.interstitialId,
      request: _req,
      adLoadCallback: InterstitialAdLoadCallback(
        onAdLoaded: (ad) {
          interstitialAd = ad;
          Log.i('Interstitial loaded');
        },
        onAdFailedToLoad: (e) {
          Log.i('Interstitial error: ${e.code}');
          Future.delayed(const Duration(seconds: 30), loadInterstitial);
        },
      ),
    );
  }

  void showInterstitial() {
    final ad = interstitialAd;
    if (ad == null) {
      loadInterstitial();
      return;
    }
    ad.fullScreenContentCallback = FullScreenContentCallback(
      onAdDismissedFullScreenContent: (a) {
        a.dispose();
        interstitialAd = null;
        loadInterstitial();
      },
      onAdFailedToShowFullScreenContent: (a, _) {
        a.dispose();
        interstitialAd = null;
        loadInterstitial();
      },
    );
    ad.show();
  }

  void loadRewarded() {
    if (rewardedAd != null) return;
    RewardedAd.load(
      adUnitId: AdIds.rewardedId,
      request: _req,
      rewardedAdLoadCallback: RewardedAdLoadCallback(
        onAdLoaded: (ad) {
          rewardedAd = ad;
          Log.i('Rewarded loaded');
        },
        onAdFailedToLoad: (e) {
          Log.i('Rewarded error: ${e.code}');
          Future.delayed(const Duration(seconds: 30), loadRewarded);
        },
      ),
    );
  }

  void showRewarded(VoidCallback onEarned) {
    final ad = rewardedAd;
    if (ad == null) {
      loadRewarded();
      return;
    }
    ad.fullScreenContentCallback = FullScreenContentCallback(
      onAdDismissedFullScreenContent: (a) {
        a.dispose();
        rewardedAd = null;
        loadRewarded();
      },
      onAdFailedToShowFullScreenContent: (a, _) {
        a.dispose();
        rewardedAd = null;
        loadRewarded();
      },
    );
    ad.show(onUserEarnedReward: (_, __) {
      Log.i('Reward earned — 2 min PRO granted');
      onEarned();
    });
  }

  void disposeAll() {
    bannerAd?.dispose();
    interstitialAd?.dispose();
    rewardedAd?.dispose();
    bannerAd = null;
    interstitialAd = null;
    rewardedAd = null;
    bannerLoaded = false;
  }
}

