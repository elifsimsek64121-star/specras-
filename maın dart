// ─────────────────────────────────────────────
//  ANALYTICS PAGE
// ─────────────────────────────────────────────
class _AnalyticsPage extends StatelessWidget {
  final _RootShellState s;
  const _AnalyticsPage({required this.s});

  @override
  Widget build(BuildContext context) {
    final dur = s._sessionStart != null
        ? DateTime.now().difference(s._sessionStart!)
        : Duration.zero;
    final durStr =
        '${dur.inMinutes}:${(dur.inSeconds % 60).toString().padLeft(2, '0')}';
    final avgSig = s._readings.isEmpty
        ? 0.0
        : s._readings.map((r) => r.fieldStrength).reduce((a, b) => a + b) /
            s._readings.length;
    final goldCount = s._detections.where((d) => d.type == 'gold').length;
    final ferrCount = s._detections.where((d) => d.type == 'ferrous').length;
    final nonFCount = s._detections.where((d) => d.type == 'nonferrous').length;

    return SafeArea(
      child: SingleChildScrollView(
        physics: const BouncingScrollPhysics(),
        padding: const EdgeInsets.fromLTRB(16, 8, 16, 100),
        child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
          const _PageTitle(title: 'ANALİTİK'),
          const SizedBox(height: 16),

          // Stats grid
          GridView.count(
            crossAxisCount: 2,
            shrinkWrap: true,
            physics: const NeverScrollableScrollPhysics(),
            crossAxisSpacing: 10,
            mainAxisSpacing: 10,
            childAspectRatio: 1.6,
            children: [
              _StatCard('Oturum', durStr, AppColors.cyan, Icons.timer_rounded),
              _StatCard('Tespit', '${s._totalDet}', AppColors.red,
                  Icons.warning_rounded),
              _StatCard('Okuma', '${s._readings.length}', AppColors.green,
                  Icons.data_usage_rounded),
              _StatCard('Ort. Sig', '${avgSig.toStringAsFixed(1)} µT',
                  AppColors.orange, Icons.show_chart_rounded),
            ],
          ),

          const SizedBox(height: 20),

          // Metal type breakdown
          const _SectionLabel('METAL TÜRÜ DAĞILIMI'),
          const SizedBox(height: 10),
          _MetalBreakdown(
              gold: goldCount,
              ferrous: ferrCount,
              nonFerrous: nonFCount,
              total: s._totalDet,
              isPro: s._tier == SubscriptionTier.pro),

          const SizedBox(height: 20),

          // Detection history
          _SectionLabel('TESPİT GEÇMİŞİ (${s._detections.length})'),
          const SizedBox(height: 10),

          if (s._detections.isEmpty)
            Center(
                child: Padding(
              padding: const EdgeInsets.symmetric(vertical: 32),
              child: Column(children: [
                Icon(Icons.radar_rounded, color: AppColors.textDim, size: 36),
                const SizedBox(height: 8),
                Text(s._calibDone ? 'Henüz tespit yok' : 'Kalibre ediliyor...',
                    style: const TextStyle(
                        color: AppColors.textSec, fontSize: 13)),
              ]),
            ))
          else
            ...s._detections.reversed.take(30).map((d) => _DetectionTile(d: d)),
        ]),
      ),
    );
  }
}

