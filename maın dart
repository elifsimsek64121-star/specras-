// ── Gauge ─────────────────────────────────────
class _GaugeWidget extends StatelessWidget {
  final _RootShellState s;
  const _GaugeWidget({required this.s});

  @override
  Widget build(BuildContext context) {
    final sz = MediaQuery.of(context).size.width * 0.62;
    final col = s._sigColor;
    final isDetect = s._signal > s._alertThr * 0.5;

    return AnimatedBuilder(
      animation: s._pulseAnim,
      builder: (_, __) {
        final scale = isDetect ? s._pulseAnim.value : 1.0;
        return Transform.scale(
          scale: scale,
          child: SizedBox(
            width: sz,
            height: sz,
            child: Stack(alignment: Alignment.center, children: [
              // Glow rings
              ...List.generate(
                  3,
                  (i) => AnimatedBuilder(
                        animation: s._scanAnim,
                        builder: (_, __) {
                          final progress = (s._scanAnim.value + i * 0.33) % 1.0;
                          return Transform.scale(
                            scale: 0.5 + progress * 0.5,
                            child: Container(
                              width: sz,
                              height: sz,
                              decoration: BoxDecoration(
                                shape: BoxShape.circle,
                                border: Border.all(
                                  color: col.withOpacity(
                                      (1 - progress) * (isDetect ? 0.6 : 0.2)),
                                  width: 1.5,
                                ),
                              ),
                            ),
                          );
                        },
                      )),

              // BG circle
              Container(
                width: sz * 0.82,
                height: sz * 0.82,
                decoration: BoxDecoration(
                  shape: BoxShape.circle,
                  color: AppColors.surface,
                  border: Border.all(color: col.withOpacity(0.4), width: 1.5),
                ),
              ),

              // Radial progress
              SizedBox(
                width: sz * 0.82,
                height: sz * 0.82,
                child: CircularProgressIndicator(
                  value: s._signal / 100,
                  strokeWidth: 4,
                  backgroundColor: AppColors.border,
                  valueColor: AlwaysStoppedAnimation<Color>(col),
                  strokeCap: StrokeCap.round,
                ),
              ),

              // Center content
              Column(mainAxisAlignment: MainAxisAlignment.center, children: [
                if (s._detType == 'gold')
                  const Icon(Icons.star, color: AppColors.gold, size: 18),
                Text(
                  s._signal.toStringAsFixed(1),
                  style: TextStyle(
                    fontSize: sz * 0.28,
                    fontWeight: FontWeight.w900,
                    color: col,
                    fontFamily: AppText.mono,
                  ),
                ),
                Text('μT',
                    style: TextStyle(
                      fontSize: sz * 0.09,
                      color: col.withOpacity(0.7),
                      fontWeight: FontWeight.w600,
                    )),
                if (s._detected)
                  Padding(
                    padding: const EdgeInsets.only(top: 4),
                    child: Text(
                      '${(s._detConf * 100).toStringAsFixed(0)}% güven',
                      style: const TextStyle(
                        fontSize: 10,
                        color: AppColors.textSec,
                        fontFamily: AppText.mono,
                      ),
                    ),
                  ),
              ]),
            ]),
          ),
        );
      },
    );
  }
}

