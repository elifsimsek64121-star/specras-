class _Shell extends StatefulWidget {
  const _Shell();

  @override
  State<_Shell> createState() => _ShellState();
}

class _ShellState extends State<_Shell>
    with TickerProviderStateMixin, WidgetsBindingObserver {
  // ── navigation ─────────────────────────────
  int _tab = 0;
  late final PageController _pc;

  // ── IAP ────────────────────────────────────
  Tier _tier = Tier.free;
  bool _iapReady = false;
  bool _iapBuying = false;
  final _iap = InAppPurchase.instance;
  StreamSubscription<List<PurchaseDetails>>? _iapSub;
  List<ProductDetails> _products = [];

  // ── DSP constants ──────────────────────────
  static const _HIST_SIZE = 300; // ring buffer length
  static const _EMA_FAST = 0.15; // fast EMA (display smoothing)
  static const _EMA_SLOW = 0.04; // slow EMA (baseline tracking)
  static const _JUMP_THR = 25.0; // jump-noise suppressor

  // ── raw sensor ─────────────────────────────
  double _rawX = 0, _rawY = 0, _rawZ = 0;
  double _rawMag = 0; // √(x²+y²+z²)

  // ── filter chain ───────────────────────────
  double _emaFast = 50; // display filter
  double _emaSlow = 50; // baseline tracker
  double _prevRaw = 50;

  // ── calibration ────────────────────────────
  final _calBuf = <double>[]; // filled during 10-s cal window
  double _baseline = 50;
  double _noiseFloor = 1.5; // 2 × stddev computed after cal
  bool _caling = false;
  bool _calDone = false;
  int _calPct = 0;
  String _calMsg = 'Waiting for sensor…';

  // ── live metrics ───────────────────────────
  double _signal = 0; // 0–100 normalised
  double _mMin = 9999;
  double _mMax = 0;
  bool _monitoring = false;

  // ── ring buffer for waveform ───────────────
  final _hist = List<double>.filled(_HIST_SIZE, 0.0);
  int _hIdx = 0;

  // ── detection state ─────────────────────────
  bool _det = false;
  String _detType = 'none';
  double _detConf = 0;
  int _totalDet = 0;
  final _detections = <DetectionEvent>[];
  final _readings = <MagReading>[];

  // ── alert config ────────────────────────────
  double _sens = 6.0;
  double _alertT = 20.0;
  double _strongT = 55.0;
  double _goldT = 78.0;
  bool _sndOn = true;
  bool _vibOn = true;
  bool _autoC = true;

  // ── audio ───────────────────────────────────
  final _audio = AudioPlayer();
  bool _beeping = false;
  double _bSpd = 1.0;
  DateTime? _lastBUpd, _lastVib;

  // ── animations ──────────────────────────────
  late AnimationController _pulseCtrl, _scanCtrl, _ringCtrl;
  late Animation<double> _pulseAnim, _scanAnim, _ringAnim;

  // ── session ─────────────────────────────────
  DateTime? _sessStart;
  int _totalSamples = 0;

  // ── UI throttle ─────────────────────────────
  Timer? _uiTimer;
  bool _ready = false;

  late SharedPreferences _prefs;
  StreamSubscription<MagnetometerEvent>? _magSub;

  // ════════════════════════════════════════════
  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addObserver(this);
    _pc = PageController();
    _setupAnims();
    _boot();
  }

  @override
  void didChangeAppLifecycleState(AppLifecycleState s) {
    if (s == AppLifecycleState.paused) _magSub?.pause();
    if (s == AppLifecycleState.resumed) _magSub?.resume();
  }

  // ── BOOT ────────────────────────────────────
  Future<void> _boot() async {
    Log.i('=== SPECTRA PRO v3.0 STARTING ===');
    _prefs = await SharedPreferences.getInstance();
    _loadPrefs();

    _iapSub = _iap.purchaseStream.listen(
      _onPurchase,
      onError: (dynamic e) => Log.i('❌ IAP stream: $e'),
    );
    final avail = await _iap.isAvailable();
    _iapReady = avail;
    Log.i('IAP available: $avail');
    if (avail) {
      await _loadProducts();
      await _iap.restorePurchases();
    }

    try {
      await _audio.setAsset('assets/beep.mp3');
      await _audio.setLoopMode(LoopMode.one);
      await _audio.setVolume(_sndOn ? 0.85 : 0.0);
      Log.i('✅ Audio ready');
    } catch (e) {
      Log.i('⚠️ Audio init: $e');
    }

    _sessStart = DateTime.now();
    _startMagnetometer();

    if (mounted) setState(() => _ready = true);
    await Future.delayed(const Duration(milliseconds: 300));
    if (mounted) await _runCalibration();
    Log.i('=== BOOT COMPLETE ===');
  }

  void _loadPrefs() {
    _sndOn = _prefs.getBool('snd') ?? true;
    _vibOn = _prefs.getBool('vib') ?? true;
    _sens = _prefs.getDouble('sens') ?? 6.0;
    _alertT = _prefs.getDouble('alt') ?? 20.0;
    _strongT = _prefs.getDouble('str') ?? 55.0;
    _goldT = _prefs.getDouble('gld') ?? 78.0;
    _autoC = _prefs.getBool('autoc') ?? true;
    _tier =
        (_prefs.getString('tier') ?? 'free') == 'pro' ? Tier.pro : Tier.free;
    Log.i('Prefs loaded – tier=$_tier');
  }

  void _savePrefs() {
    _prefs
      ..setBool('snd', _sndOn)
      ..setBool('vib', _vibOn)
      ..setDouble('sens', _sens)
      ..setDouble('alt', _alertT)
      ..setDouble('str', _strongT)
      ..setDouble('gld', _goldT)
      ..setBool('autoc', _autoC);
  }

  // ── IAP ─────────────────────────────────────
  Future<void> _loadProducts() async {
    try {
      final res = await _iap.queryProductDetails(IAP.ids);
      if (res.error != null) Log.i('⚠️ IAP query error: ${res.error}');
      if (res.notFoundIDs.isNotEmpty) Log.i('⚠️ Not found: ${res.notFoundIDs}');
      _products = res.productDetails;
      Log.i(
          'Products: ${_products.map((p) => "${p.id}:${p.price}").join(", ")}');
    } catch (e) {
      Log.i('❌ _loadProducts: $e');
    }
  }

  Future<void> _onPurchase(List<PurchaseDetails> purchases) async {
    for (final p in purchases) {
      Log.i('🛒 Purchase: ${p.productID} status=${p.status}');
      if (p.status == PurchaseStatus.purchased ||
          p.status == PurchaseStatus.restored) {
        _grantPro(p.productID);
        await _iap.completePurchase(p);
      } else if (p.status == PurchaseStatus.error) {
        if (mounted) {
          setState(() => _iapBuying = false);
          _snack('Purchase failed: ${p.error?.message}', C.red);
        }
        await _iap.completePurchase(p);
      } else if (p.status == PurchaseStatus.canceled) {
        if (mounted) setState(() => _iapBuying = false);
      }
    }
  }

  void _grantPro(String productId) {
    Log.i('✅ PRO granted via $productId');
    if (!mounted) return;
    setState(() {
      _tier = Tier.pro;
      _iapBuying = false;
    });
    _prefs.setString('tier', 'pro');
    _snack('🎉 PRO activated! All features unlocked.', C.gold);
  }

  Future<void> _buyProduct(ProductDetails pd) async {
    setState(() => _iapBuying = true);
    try {
      final ok = await _iap.buyNonConsumable(
        purchaseParam: PurchaseParam(productDetails: pd),
      );
      if (!ok && mounted) setState(() => _iapBuying = false);
    } catch (e) {
      Log.i('❌ buyProduct: $e');
      if (mounted) setState(() => _iapBuying = false);
    }
  }

  Future<void> _restorePurchases() async {
    setState(() => _iapBuying = true);
    await _iap.restorePurchases();
    await Future.delayed(const Duration(seconds: 4));
    if (mounted) setState(() => _iapBuying = false);
  }

  ProductDetails? _pd(String id) {
    try {
      return _products.firstWhere((p) => p.id == id);
    } catch (_) {
      return null;
    }
  }

  // ── ANIMATIONS ──────────────────────────────
  void _setupAnims() {
    _pulseCtrl = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 1600),
    )..repeat(reverse: true);
    _pulseAnim = Tween(begin: 0.92, end: 1.08).animate(
      CurvedAnimation(parent: _pulseCtrl, curve: Curves.easeInOutSine),
    );

    _scanCtrl = AnimationController(
      vsync: this,
      duration: const Duration(seconds: 3),
    )..repeat();
    _scanAnim = Tween(begin: 0.0, end: 1.0).animate(
      CurvedAnimation(parent: _scanCtrl, curve: Curves.linear),
    );

    _ringCtrl = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 900),
    )..repeat(reverse: true);
    _ringAnim = Tween(begin: 0.4, end: 1.0).animate(
      CurvedAnimation(parent: _ringCtrl, curve: Curves.easeInOut),
    );
  }

  // ── MAGNETOMETER (REAL SENSOR) ───────────────
  void _startMagnetometer() {
    _magSub?.cancel();
    _magSub = magnetometerEventStream(
      samplingPeriod: SensorInterval.uiInterval, // ~60 Hz
    ).listen(
      _onMagEvent,
      onError: (dynamic err) {
        Log.i('❌ Sensor: $err');
        if (mounted) setState(() => _calMsg = 'Sensor Error');
      },
    );
  }

  void _onMagEvent(MagnetometerEvent e) {
    _rawX = e.x;
    _rawY = e.y;
    _rawZ = e.z;
    _rawMag = sqrt(e.x * e.x + e.y * e.y + e.z * e.z);
    _totalSamples++;

    // Jump-noise suppression: large transients slow-track to avoid spikes
    final diff = (_rawMag - _prevRaw).abs();
    final weight = diff > _JUMP_THR ? 0.03 : _EMA_FAST;
    _emaFast = weight * _rawMag + (1 - weight) * _emaFast;
    _prevRaw = _rawMag;

    // Collect calibration samples
    if (_caling) {
      _calBuf.add(_rawMag);
    }

    if (_calDone && _monitoring) {
      // Slow baseline drift tracker (very slow – ignores detections)
      if (_signal < _alertT * 0.5) {
        _emaSlow = _EMA_SLOW * _rawMag + (1 - _EMA_SLOW) * _emaSlow;
      }

      // Deviation from baseline → normalised signal 0–100
      final dev = (_emaFast - _baseline).abs();
      _signal = (dev / _noiseFloor * _sens * 1.2).clamp(0, 100);

      if (_emaFast < _mMin) _mMin = _emaFast;
      if (_emaFast > _mMax) _mMax = _emaFast;

      // Ring buffer
      _hist[_hIdx] = _emaFast;
      _hIdx = (_hIdx + 1) % _HIST_SIZE;

      // Record for export
      _readings.add(MagReading(
        ts: DateTime.now(),
        x: _rawX,
        y: _rawY,
        z: _rawZ,
        raw: _rawMag,
        signal: _signal,
      ));
      if (_readings.length > 5000) _readings.removeAt(0);

      _classify();
      _feedback();
    }

    _schedUI();
  }

  // ── CALIBRATION ─────────────────────────────
  Future<void> _runCalibration() async {
    if (_caling) return;
    Log.i('🔄 Calibration start');

    if (mounted)
      setState(() {
        _caling = true;
        _calDone = false;
        _calPct = 0;
        _calMsg = 'Hold still – calibrating…';
        _monitoring = false;
        _det = false;
        _beeping = false;
        _signal = 0;
        _calBuf.clear();
        _hist.fillRange(0, _HIST_SIZE, 0.0);
        _hIdx = 0;
        _mMin = 9999;
        _mMax = 0;
      });
    _audio.stop();

    // 10-second window collecting raw samples
    for (int i = 0; i < 10; i++) {
      if (!mounted) return;
      await Future.delayed(const Duration(seconds: 1));
      if (mounted)
        setState(() {
          _calPct = ((i + 1) * 10);
          _calMsg = 'Calibrating… ${i + 1}/10s';
        });
    }

    _computeBaseline();

    if (mounted)
      setState(() {
        _caling = false;
        _calDone = true;
        _monitoring = true;
        _calPct = 100;
        _calMsg = 'Calibrated – Active monitoring';
      });
    Log.i('✅ Cal done baseline=${_baseline.toStringAsFixed(2)} '
        'noise=${_noiseFloor.toStringAsFixed(2)}');
  }

  void _computeBaseline() {
    if (_calBuf.isEmpty) {
      _baseline = _rawMag.isFinite ? _rawMag : 50;
      _noiseFloor = 2.0;
      return;
    }

    final sorted = List<double>.from(_calBuf)..sort();
    final q1 = sorted[(sorted.length * 0.25).toInt()];
    final q3 = sorted[(sorted.length * 0.75).toInt()];
    final iqr = q3 - q1;
    final fence = iqr * 1.5;
    final clean =
        sorted.where((v) => v >= q1 - fence && v <= q3 + fence).toList();
    final src = clean.isNotEmpty ? clean : sorted;

    _baseline = src.reduce((a, b) => a + b) / src.length;

    // Noise floor = 2 × standard deviation of the clean window
    final variance =
        src.map((v) => pow(v - _baseline, 2)).reduce((a, b) => a + b) /
            src.length;
    _noiseFloor = max(1.0, 2.0 * sqrt(variance));

    _emaFast = _baseline;
    _emaSlow = _baseline;
    _mMin = _baseline;
    _mMax = _baseline;
    _calBuf.clear();
  }

  // ── CLASSIFICATION ───────────────────────────
  void _classify() {
    if (_signal > _alertT) {
      if (_tier == Tier.pro && _signal > _goldT) {
        _detType = 'gold';
        _detConf = _calcGoldConf();
      } else if (_signal > _strongT) {
        _detType = 'ferrous';
        _detConf = (0.91 + (_signal - _strongT) * 0.0015).clamp(0, 0.99);
      } else {
        _detType = 'nonferrous';
        _detConf = (0.68 + (_signal - _alertT) * 0.004).clamp(0, 0.99);
      }

      if (!_det) {
        _totalDet++;
        _det = true;
        _detections.add(DetectionEvent(
          ts: DateTime.now(),
          type: _detType,
          conf: _detConf,
          signal: _signal,
          label: _detLabel(),
          color: _detColor(_detType),
          icon: _detIcon(_detType),
        ));
        if (_detections.length > 500) _detections.removeAt(0);
        Log.i('🔴 $_detType sig=${_signal.toStringAsFixed(1)} '
            'conf=${(_detConf * 100).toStringAsFixed(0)}%');
      }
    } else if (_det) {
      _det = false;
      _detType = 'none';
      _detConf = 0;
    }
  }

  double _calcGoldConf() {
    // Stability bonus: very stable field → more likely genuine
    final recent = List.generate(
      25,
      (i) => _hist[(_hIdx - 1 - i + _HIST_SIZE) % _HIST_SIZE],
    );
    final mean = recent.reduce((a, b) => a + b) / recent.length;
    final variance =
        recent.map((v) => (v - mean) * (v - mean)).reduce((a, b) => a + b) /
            recent.length;
    double conf = 0.80;
    if (variance < 3) conf += 0.08;
    if (_signal > _goldT + 10) conf += 0.06;
    return conf.clamp(0, 0.99);
  }

  String _detLabel() => switch (_detType) {
        'gold' => 'GOLD DETECTED',
        'ferrous' => 'Iron / Steel',
        'nonferrous' => 'Non-Ferrous Metal',
        _ => 'Signal',
      };

  Color _detColor(String t) => switch (t) {
        'gold' => C.gold,
        'ferrous' => C.red,
        'nonferrous' => C.orange,
        _ => C.tSec,
      };

  IconData _detIcon(String t) => switch (t) {
        'gold' => Icons.star_rounded,
        'ferrous' => Icons.bolt_rounded,
        'nonferrous' => Icons.radio_button_checked_rounded,
        _ => Icons.circle_outlined,
      };

  // ── AUDIO / HAPTIC FEEDBACK ──────────────────
  void _feedback() {
    if (_signal > _alertT) {
      if (_sndOn) {
        final spd = (0.5 + (_signal / 100) * 2.2).clamp(0.5, 2.5);
        if (!_beeping) {
          _audio.play();
          _beeping = true;
        }
        final now = DateTime.now();
        if (_lastBUpd == null ||
            now.difference(_lastBUpd!).inMilliseconds > 80) {
          if ((spd - _bSpd).abs() > 0.08) {
            _audio.setSpeed(spd);
            _bSpd = spd;
          }
          _lastBUpd = now;
        }
      }
      if (_vibOn) {
        final now = DateTime.now();
        final gap = _detType == 'gold' ? 180 : (_signal > _strongT ? 260 : 380);
        if (_lastVib == null ||
            now.difference(_lastVib!).inMilliseconds > gap) {
          try {
            Vibration.vibrate(
              duration:
                  _detType == 'gold' ? 320 : (_signal > _strongT ? 200 : 120),
              amplitude:
                  _detType == 'gold' ? 255 : (_signal > _strongT ? 220 : 140),
            );
          } catch (_) {}
          _lastVib = now;
        }
      }
    } else if (_beeping) {
      _audio.stop();
      _beeping = false;
      _bSpd = 1.0;
    }
  }

  void _schedUI() {
    _uiTimer?.cancel();
    _uiTimer = Timer(const Duration(milliseconds: 50), () {
      if (mounted) setState(() {});
    });
  }

  // ── PRO WALL ────────────────────────────────
  void _showProWall() => showModalBottomSheet(
        context: context,
        backgroundColor: C.card,
        isScrollControlled: true,
        shape: const RoundedRectangleBorder(
          borderRadius: BorderRadius.vertical(top: Radius.circular(28)),
        ),
        builder: (_) => _ProSheet(
          annual: _pd(IAP.annual),
          monthly: _pd(IAP.monthly),
          busy: _iapBuying,
          iapReady: _iapReady,
          onBuyAnnual: () {
            Navigator.pop(context);
            final p = _pd(IAP.annual);
            if (p != null)
              _buyProduct(p);
            else
              _noProducts();
          },
          onBuyMonthly: () {
            Navigator.pop(context);
            final p = _pd(IAP.monthly);
            if (p != null)
              _buyProduct(p);
            else
              _noProducts();
          },
          onRestore: () {
            Navigator.pop(context);
            _restorePurchases();
          },
        ),
      );

  void _noProducts() => showDialog(
        context: context,
        builder: (_) => AlertDialog(
          backgroundColor: C.card,
          title:
              const Text('Store Unavailable', style: TextStyle(color: C.tPrim)),
          content: const Text(
            'Cannot load products from Google Play.\nCheck your internet connection.',
            style: TextStyle(color: C.tSec),
          ),
          actions: [
            TextButton(
              onPressed: () => Navigator.pop(context),
              child: const Text('OK', style: TextStyle(color: C.cyan)),
            ),
          ],
        ),
      );

  // ── HELPERS ─────────────────────────────────
  Color get _sigCol {
    if (_signal > _goldT && _tier == Tier.pro) return C.gold;
    if (_signal > _strongT) return C.red;
    if (_signal > _alertT) return C.orange;
    if (_signal > _alertT * 0.4) return C.cyan;
    return C.green;
  }

  String get _statusLbl {
    if (_caling) return _calMsg;
    if (!_calDone) return 'Starting…';
    if (_det) {
      return switch (_detType) {
        'gold' => '⚡ GOLD DETECTED',
        'ferrous' => '● FERROUS METAL',
        'nonferrous' => '◆ METAL DETECTED',
        _ => '◆ SIGNAL',
      };
    }
    return _monitoring ? '● Scanning Active' : '❚❚ Paused';
  }

  void _snack(String msg, Color bg) {
    if (!mounted) return;
    ScaffoldMessenger.of(context).showSnackBar(SnackBar(
      content: Text(msg),
      backgroundColor: bg,
      duration: const Duration(seconds: 4),
    ));
  }

  // ── DISPOSE ─────────────────────────────────
  @override
  void dispose() {
    WidgetsBinding.instance.removeObserver(this);
    _magSub?.cancel();
    _iapSub?.cancel();
    _uiTimer?.cancel();
    _audio.dispose();
    _pulseCtrl.dispose();
    _scanCtrl.dispose();
    _ringCtrl.dispose();
    _pc.dispose();
    super.dispose();
  }

  // ════════════════════════════════════════════
  // BUILD
  // ════════════════════════════════════════════
  @override
  Widget build(BuildContext context) {
    if (!_ready) return const _Splash();

    return Scaffold(
      backgroundColor: C.bg,
      extendBody: true,
      body: Stack(children: [
        PageView(
          controller: _pc,
          physics: const NeverScrollableScrollPhysics(),
          children: [
