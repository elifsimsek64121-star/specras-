class _DebugPageState extends State<_DebugPage> {
  @override
  Widget build(BuildContext context) {
    final s = widget.state;
    final logs = Log.all;

    return SafeArea(
      child: Column(
        children: [
          Padding(
            padding: const EdgeInsets.fromLTRB(16, 14, 16, 10),
            child: Column(
              children: [
                const _SectionLabel('DEBUG CONSOLE', large: true),
                const SizedBox(height: 12),
                Row(
                  children: [
                    Expanded(
                        child: _DbgBtn(
                      label: 'Clear',
                      icon: Icons.delete_rounded,
                      color: C.red,
                      onTap: () {
                        Log.clear();
                        setState(() {});
                      },
                    )),
                    const SizedBox(width: 10),
                    Expanded(
                        child: _DbgBtn(
                      label: 'Refresh',
                      icon: Icons.refresh_rounded,
                      color: C.cyan,
                      onTap: () => setState(() {}),
                    )),
                    const SizedBox(width: 10),
                    Expanded(
                        child: _DbgBtn(
                      label: 'Test Audio',
                      icon: Icons.volume_up_rounded,
                      color: C.orange,
                      onTap: () async {
                        try {
                          await s._audio.setVolume(s._audioVol);
                          await s._audio.play();
                          await Future.delayed(
                              const Duration(milliseconds: 500));
                          await s._audio.stop();
                        } catch (e) {
                          Log.i('Audio test error: $e');
                        }
                      },
                    )),
                  ],
                ),
              ],
            ),
          ),
          Container(height: 1, color: C.border),
          Expanded(
            child: logs.isEmpty
                ? const Center(
                    child: Text('No logs yet', style: TextStyle(color: C.tDim)))
                : ListView.builder(
                    reverse: true,
                    padding: const EdgeInsets.fromLTRB(16, 8, 16, 16),
                    itemCount: logs.length,
                    itemBuilder: (_, i) {
                      final log = logs[logs.length - 1 - i];
                      Color col = C.tSec;
                      if (log.contains('❌') ||
                          log.contains('error') ||
                          log.contains('failed')) col = C.red;
                      if (log.contains('✅') || log.contains('Success'))
                        col = C.green;
                      if (log.contains('Purchase') || log.contains('IAP'))
                        col = C.cyan;
                      if (log.contains('PRO') || log.contains('active'))
                        col = C.purple;
                      if (log.contains('Calibrat') || log.contains('Baseline'))
                        col = C.gold;
                      if (log.contains('Reward') || log.contains('reward'))
                        col = C.orange;
                      return Text(log,
                          style: TextStyle(
                              fontSize: 9.5,
                              color: col,
                              fontFamily: C.mono,
                              height: 1.6));
                    },
                  ),
          ),
        ],
      ),
    );
  }
}

