class RootShell extends StatefulWidget {
  const RootShell({super.key});
  @override
  State<RootShell> createState() => _RootShellState();
}

class _RootShellState extends State<RootShell>
    with TickerProviderStateMixin, WidgetsBindingObserver {
  // ── Tabs ──────────────────────────────────
  int _tab = 0;
  late final PageController _pageCtrl;

  // ── Subscription ─────────────────────────
  SubscriptionTier _tier = SubscriptionTier.free;

  // ── Sensor raw ────────────────────────────
  static const int _histSz = 500;
  final List<double> _magHist = List.filled(500, 50.0);
  int _histIdx = 0;
  double _magX = 0, _magY = 0, _magZ = 0;
  double _magRaw = 50.0;
  double _magFilt = 50.0;
  double _baseline = 50.0;
  double _magMin = 50.0, _magMax = 50.0;
  double _signal = 0.0; // 0..100

  // ── Calibration ───────────────────────────
  bool _calibrating = false;
  bool _calibDone = false;
  bool _monitoring = false;
  int _calibProgress = 0;
  String _calibMsg = 'Başlatılıyor...';

  // ── Detection ─────────────────────────────
  bool _detected = false;
  String _detType = 'none';
  double _detConf = 0.0;
  final List<Detection> _detections = [];
  final List<MagReading> _readings = [];
  int _totalDet = 0;

  // ── DSP params ────────────────────────────
  static const double _emaA = 0.10;
  static const double _jumpThr = 30.0;

  // ── Settings ──────────────────────────────
  double _sensitivity = 8.0;
  double _alertThr = 30.0;
  double _strongThr = 70.0;
  double _goldThr = 85.0;
  bool _soundOn = true;
  bool _vibOn = true;
  bool _autoCalib = true;

  // ── Audio ─────────────────────────────────
  final _audio = AudioPlayer();
  bool _beeping = false;
  double _beepSpd = 1.0;
  DateTime? _lastBeepUpd;
  DateTime? _lastVib;

  // ── Animations ────────────────────────────
  late AnimationController _pulseCtrl, _scanCtrl, _ringCtrl;
  late Animation<double> _pulseAnim, _scanAnim, _ringAnim;

  // ── Session ───────────────────────────────
  DateTime? _sessionStart;
  int _dataPoints = 0;

  // ── Bluetooth (PRO) ───────────────────────
  bool _btScanning = false;
  bool _btConnected = false;
  BluetoothDevice? _btDevice;
  StreamSubscription<List<ScanResult>>? _btScanSub;
  StreamSubscription<List<int>>? _btCharSub;
  final List<ScanResult> _btResults = [];
  BtSensorData? _btData;
  String _btStatus = 'Bağlı değil';

  // ── Prefs ─────────────────────────────────
  late SharedPreferences _prefs;
  StreamSubscription<MagnetometerEvent>? _magSub;
  Timer? _uiTimer;

  bool _inited = false;

  // ════════════════════════════════════════════
  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addObserver(this);
    _pageCtrl = PageController();
    _setupAnim();
    _init();
  }

  @override
  void didChangeAppLifecycleState(AppLifecycleState s) {
    if (s == AppLifecycleState.paused) {
      _magSub?.pause();
    }
    if (s == AppLifecycleState.resumed) {
      _magSub?.resume();
    }
  }

  // ── Init ──────────────────────────────────
  Future<void> _init() async {
    try {
      AppLog.log('=== SPECTRA PRO BAŞLATILIYOR ===');
      _prefs = await SharedPreferences.getInstance();
      _loadPrefs();
      AppLog.log('✅ Ayarlar yüklendi');

      await _initAudio();
      AppLog.log('✅ Ses sistemi hazır');

      _sessionStart = DateTime.now();
      _startMag();
      AppLog.log('✅ Manyetometre aktif');

      if (mounted) setState(() => _inited = true);
      await Future.delayed(const Duration(milliseconds: 300));
      if (mounted) await _calibrate();
      AppLog.log('=== BAŞLATMA TAMAMLANDI ===');
    } catch (e) {
      AppLog.log('❌ HATA: $e');
    }
  }

  void _loadPrefs() {
    _soundOn = _prefs.getBool('sound') ?? true;
    _vibOn = _prefs.getBool('vib') ?? true;
    _sensitivity = _prefs.getDouble('sens') ?? 8.0;
    _alertThr = _prefs.getDouble('alert') ?? 30.0;
    _strongThr = _prefs.getDouble('strong') ?? 70.0;
    _goldThr = _prefs.getDouble('gold') ?? 85.0;
    _autoCalib = _prefs.getBool('autocalib') ?? true;
    final tierStr = _prefs.getString('tier') ?? 'free';
    _tier = tierStr == 'pro' ? SubscriptionTier.pro : SubscriptionTier.free;
  }

  void _savePrefs() {
    _prefs.setBool('sound', _soundOn);
    _prefs.setBool('vib', _vibOn);
    _prefs.setDouble('sens', _sensitivity);
    _prefs.setDouble('alert', _alertThr);
    _prefs.setDouble('strong', _strongThr);
    _prefs.setDouble('gold', _goldThr);
    _prefs.setBool('autocalib', _autoCalib);
  }

  // ── Animations ────────────────────────────
  void _setupAnim() {
    _pulseCtrl = AnimationController(
        vsync: this, duration: const Duration(milliseconds: 1400))
      ..repeat(reverse: true);
    _pulseAnim = Tween<double>(begin: 0.88, end: 1.12).animate(
        CurvedAnimation(parent: _pulseCtrl, curve: Curves.easeInOutSine));

    _scanCtrl =
        AnimationController(vsync: this, duration: const Duration(seconds: 2))
          ..repeat();
    _scanAnim = Tween<double>(begin: 0, end: 1)
        .animate(CurvedAnimation(parent: _scanCtrl, curve: Curves.linear));

    _ringCtrl = AnimationController(
        vsync: this, duration: const Duration(milliseconds: 800))
      ..repeat(reverse: true);
    _ringAnim = Tween<double>(begin: 0.3, end: 1.0)
        .animate(CurvedAnimation(parent: _ringCtrl, curve: Curves.easeInOut));
  }

  // ── Audio ─────────────────────────────────
  Future<void> _initAudio() async {
    try {
      await _audio.setAsset('assets/beep.mp3');
      await _audio.setLoopMode(LoopMode.one);
      await _audio.setVolume(_soundOn ? 0.8 : 0.0);
    } catch (e) {
      AppLog.log('⚠️ Ses: $e');
    }
  }

  // ── Magnetometer ─────────────────────────
  void _startMag() {
    _magSub?.cancel();
    _magSub = magnetometerEventStream(samplingPeriod: SensorInterval.uiInterval)
        .listen((e) {
      _magX = e.x;
      _magY = e.y;
      _magZ = e.z;
      _magRaw = sqrt(e.x * e.x + e.y * e.y + e.z * e.z);

      final diff = (_magRaw - _magFilt).abs();
      if (diff > _jumpThr) {
        _magFilt += (_magRaw - _magFilt) * 0.05;
      } else {
        _magFilt = _emaA * _magRaw + (1 - _emaA) * _magFilt;
      }

      _magHist[_histIdx] = _magFilt;
      _histIdx = (_histIdx + 1) % _histSz;
      _dataPoints++;

      if (_calibDone && !_calibrating) {
        if (_magFilt < _magMin) _magMin = _magFilt;
        if (_magFilt > _magMax) _magMax = _magFilt;

        final dev = (_magFilt - _baseline).abs();
        _signal = (dev * _sensitivity * 0.85).clamp(0.0, 100.0);

        _classifyMetal();
        _doFeedback();

        if (_monitoring) {
          _readings.add(MagReading(
              ts: DateTime.now(),
              x: _magX,
              y: _magY,
              z: _magZ,
              magnitude: _magRaw,
              fieldStrength: _signal));
          if (_readings.length > 3000) _readings.removeAt(0);
        }
      }
      _scheduleUI();
    }, onError: (err) {
      AppLog.log('❌ Sensör hatası: $err');
      if (mounted)
        setState(() {
          _calibMsg = 'Sensör Hatası';
        });
    });
  }

  // ── Calibration ──────────────────────────
  Future<void> _calibrate() async {
    if (_calibrating) return;
    AppLog.log('🔄 Kalibrasyon başladı');
    if (mounted)
      setState(() {
        _calibrating = true;
        _calibDone = false;
        _calibProgress = 0;
        _calibMsg = 'Kalibre ediliyor...';
        _magHist.fillRange(0, _histSz, 50.0);
        _histIdx = 0;
        _magFilt = 50.0;
        _detected = false;
        _audio.stop();
        _beeping = false;
      });

    for (int i = 0; i < 10; i++) {
      if (!mounted) return;
      await Future.delayed(const Duration(seconds: 1));
      if (mounted)
        setState(() {
          _calibProgress = ((i + 1) / 10 * 100).toInt();
          _calibMsg = 'Kalibre ediliyor... ${i + 1}/10s';
        });
    }

    _computeBaseline();
    if (mounted)
      setState(() {
        _calibrating = false;
        _calibDone = true;
        _monitoring = true;
        _calibProgress = 100;
        _calibMsg = '✔ Hazır – İzleniyor';
      });
    AppLog.log('✅ Kalibrasyon bitti – Baz: ${_baseline.toStringAsFixed(2)} µT');
  }

  void _computeBaseline() {
    final vals = <double>[];
    final start = _histSz ~/ 4;
    for (int i = start; i < _histSz; i++) {
      final v = _magHist[(i + _histIdx) % _histSz];
      if (v > 10 && v < 130) vals.add(v);
    }
    if (vals.isEmpty) {
      _baseline = 48.0;
      return;
    }
    vals.sort();
    final q1 = vals[(vals.length * 0.25).toInt()];
    final q3 = vals[(vals.length * 0.75).toInt()];
    final iqr = q3 - q1;
    final filt =
        vals.where((v) => v >= q1 - 1.5 * iqr && v <= q3 + 1.5 * iqr).toList();
    _baseline = (filt.isNotEmpty ? filt : vals).reduce((a, b) => a + b) /
        (filt.isNotEmpty ? filt.length : vals.length);
    _magFilt = _baseline;
    _magMin = _baseline;
    _magMax = _baseline;
  }

  // ── Metal Classification ──────────────────
  void _classifyMetal() {
    if (_signal > _alertThr) {
      // PRO: gold detection uses dedicated threshold + BT data
      if (_tier == SubscriptionTier.pro && _signal > _goldThr) {
        _detType = 'gold';
        _detConf = _computeGoldConfidence();
      } else if (_signal > _strongThr) {
        _detType = 'ferrous';
        _detConf = 0.93 + (_signal - _strongThr) * 0.001;
      } else {
        _detType = 'nonferrous';
        _detConf = 0.72 + (_signal - _alertThr) * 0.003;
      }
      _detConf = _detConf.clamp(0.0, 0.99);

      if (!_detected) {
        _totalDet++;
        _detected = true;
        _detections.add(Detection(
          ts: DateTime.now(),
          type: _detType,
          confidence: _detConf,
          signal: _signal,
          label: _detLabel(),
          color: _detColor(_detType),
        ));
        if (_detections.length > 300) _detections.removeAt(0);
        AppLog.log(
            '🔴 Tespit: $_detType  |  Sinyal: ${_signal.toStringAsFixed(1)}  |  Güven: ${(_detConf * 100).toStringAsFixed(0)}%');
      }
    } else if (_detected) {
      _detected = false;
      _detType = 'none';
      _detConf = 0.0;
    }
  }

  // Gold confidence uses field gradient analysis (PRO)
  double _computeGoldConfidence() {
    // Altın non-ferrous + yüksek sinyal + BT referans varsa ekstra puan
    double base = 0.78;
    if (_btConnected && _btData != null) {
      final btMatch = (_btData!.signal - _signal).abs() < 15;
      if (btMatch) base += 0.12;
    }
    // Gradyan stabilitesi
    final recent = <double>[];
    for (int i = 0; i < 20; i++) {
      recent.add(_magHist[(_histIdx - 1 - i + _histSz) % _histSz]);
    }
    final variance = _variance(recent);
    if (variance < 5) base += 0.06; // Stabil alan = altın benzeri
    return base.clamp(0, 0.99);
  }

  double _variance(List<double> d) {
    if (d.isEmpty) return 0;
    final mean = d.reduce((a, b) => a + b) / d.length;
    return d.map((v) => (v - mean) * (v - mean)).reduce((a, b) => a + b) /
        d.length;
  }

  String _detLabel() {
    switch (_detType) {
      case 'gold':
        return 'ALTIN TESPİT EDİLDİ ✦';
      case 'ferrous':
        return 'Demir / Çelik';
      case 'nonferrous':
        return 'Demir Dışı Metal';
      default:
        return 'Sinyal';
    }
  }

  Color _detColor(String t) {
    switch (t) {
      case 'gold':
        return AppColors.gold;
      case 'ferrous':
        return AppColors.red;
      case 'nonferrous':
        return AppColors.orange;
      default:
        return AppColors.textSec;
    }
  }

  // ── Feedback ──────────────────────────────
  void _doFeedback() {
    if (_signal > _alertThr) {
      if (_soundOn) {
        final spd = (0.5 + (_signal / 100) * 2.0).clamp(0.5, 2.5);
        if (!_beeping) {
          _audio.play();
          _beeping = true;
        }
        final now = DateTime.now();
        if (_lastBeepUpd == null ||
            now.difference(_lastBeepUpd!).inMilliseconds > 100) {
          if ((spd - _beepSpd).abs() > 0.1) {
            _audio.setSpeed(spd);
            _beepSpd = spd;
          }
          _lastBeepUpd = now;
        }
      }
      if (_vibOn) {
        final now = DateTime.now();
        final gap =
            _detType == 'gold' ? 200 : (_signal > _strongThr ? 280 : 400);
        if (_lastVib == null ||
            now.difference(_lastVib!).inMilliseconds > gap) {
          try {
            Vibration.vibrate(
              duration:
                  _detType == 'gold' ? 300 : (_signal > _strongThr ? 220 : 130),
              amplitude:
                  _detType == 'gold' ? 255 : (_signal > _strongThr ? 230 : 150),
            );
          } catch (_) {}
          _lastVib = now;
        }
      }
    } else if (_beeping) {
      _audio.stop();
      _beeping = false;
      _beepSpd = 1.0;
    }
  }

  void _scheduleUI() {
    _uiTimer?.cancel();
    _uiTimer = Timer(const Duration(milliseconds: 66), () {
      if (mounted) setState(() {});
    });
  }

  // ── Bluetooth (PRO) ──────────────────────
  Future<void> _startBtScan() async {
    if (_tier != SubscriptionTier.pro) {
      _showProWall();
      return;
    }
    final stat = await Permission.bluetoothScan.request();
    if (!stat.isGranted) return;
    await Permission.bluetoothConnect.request();
    await Permission.location.request();

    if (mounted)
      setState(() {
        _btScanning = true;
        _btResults.clear();
      });
    AppLog.log('🔵 Bluetooth tarama başladı');

    try {
      await FlutterBluePlus.startScan(timeout: const Duration(seconds: 12));
      _btScanSub = FlutterBluePlus.scanResults.listen((results) {
        if (mounted)
          setState(() {
            _btResults.clear();
            _btResults.addAll(results);
          });
      });
      await Future.delayed(const Duration(seconds: 12));
    } catch (e) {
      AppLog.log('❌ BT tarama: $e');
    }
    if (mounted) setState(() => _btScanning = false);
  }

  Future<void> _connectBt(BluetoothDevice device) async {
    try {
      AppLog.log('🔵 Bağlanıyor: ${device.platformName}');
      await device.connect(timeout: const Duration(seconds: 10));
      if (mounted)
        setState(() {
          _btDevice = device;
          _btConnected = true;
          _btStatus = '${device.platformName} bağlı';
        });

      final services = await device.discoverServices();
      for (final svc in services) {
        for (final char in svc.characteristics) {
          if (char.properties.notify || char.properties.read) {
            await char.setNotifyValue(true);
            _btCharSub = char.onValueReceived.listen(_parseBtData);
            AppLog.log('✅ BT karakteristiği dinleniyor');
          }
        }
      }
    } catch (e) {
      AppLog.log('❌ BT bağlantı hatası: $e');
      if (mounted)
        setState(() {
          _btConnected = false;
          _btStatus = 'Bağlantı hatası';
        });
    }
  }

  void _parseBtData(List<int> raw) {
    try {
      final str = utf8.decode(raw);
      // Protocol: "MAG:xx.x,SIG:yy.y" ya da sadece sayısal
      double? mag, sig;
      if (str.contains('MAG:')) {
        final parts = str.split(',');
        for (final p in parts) {
          if (p.startsWith('MAG:')) mag = double.tryParse(p.substring(4));
          if (p.startsWith('SIG:')) sig = double.tryParse(p.substring(4));
        }
      } else {
        final v = double.tryParse(str.trim());
        if (v != null) {
          mag = v;
          sig = (v - _baseline).abs() * _sensitivity * 0.85;
        }
      }
      if (mag != null) {
        if (mounted)
          setState(() {
            _btData = BtSensorData(
              magnitude: mag!,
              signal: sig ?? 0,
              raw: str,
            );
          });
        AppLog.log('🔵 BT veri: $str');
      }
    } catch (e) {
      AppLog.log('⚠️ BT parse: $e');
    }
  }

  Future<void> _disconnectBt() async {
    _btCharSub?.cancel();
    _btScanSub?.cancel();
    await _btDevice?.disconnect();
    if (mounted)
      setState(() {
        _btConnected = false;
        _btDevice = null;
        _btData = null;
        _btStatus = 'Bağlı değil';
      });
    AppLog.log('🔵 Bluetooth bağlantısı kesildi');
  }

  // ── PRO Upgrade Wall ─────────────────────
  void _showProWall() {
    showModalBottomSheet(
      context: context,
      backgroundColor: AppColors.card,
      shape: const RoundedRectangleBorder(
          borderRadius: BorderRadius.vertical(top: Radius.circular(24))),
      builder: (_) => _ProUpgradeSheet(onUpgrade: () {
        setState(() {
          _tier = SubscriptionTier.pro;
          _prefs.setString('tier', 'pro');
        });
        Navigator.pop(context);
        ScaffoldMessenger.of(context).showSnackBar(const SnackBar(
          content: Text('🎉 PRO aktif! Tüm özellikler açıldı.'),
          backgroundColor: AppColors.gold,
        ));
      }),
    );
  }

  // ── Helpers ───────────────────────────────
  Color get _sigColor {
    if (_signal > _goldThr && _tier == SubscriptionTier.pro)
      return AppColors.gold;
    if (_signal > _strongThr) return AppColors.red;
    if (_signal > _alertThr) return AppColors.orange;
    if (_signal > _alertThr * 0.5) return AppColors.cyan.withOpacity(0.7);
    return AppColors.green;
  }

  String get _statusLabel {
    if (_calibrating) return _calibMsg;
    if (!_calibDone) return 'Başlatılıyor...';
    if (_detected) {
      if (_detType == 'gold') return '⚡ ALTIN TESPİT EDİLDİ';
      if (_detType == 'ferrous') return '🔴 DEMİR METAL';
      return '🟠 METAL TESPİT';
    }
    return '🟢 Tarama Aktif';
  }

  // ── Dispose ───────────────────────────────
  @override
  void dispose() {
    WidgetsBinding.instance.removeObserver(this);
    _magSub?.cancel();
    _btScanSub?.cancel();
    _btCharSub?.cancel();
    _uiTimer?.cancel();
    _audio.dispose();
    _pulseCtrl.dispose();
    _scanCtrl.dispose();
    _ringCtrl.dispose();
    _pageCtrl.dispose();
    super.dispose();
  }

  // ════════════════════════════════════════════
  //  BUILD
  // ════════════════════════════════════════════
  @override
  Widget build(BuildContext context) {
    if (!_inited) return _Splash();

    return Scaffold(
      backgroundColor: AppColors.bg,
      extendBody: true,
      body: PageView(
        controller: _pageCtrl,
        physics: const NeverScrollableScrollPhysics(),
        children: [
          _ScannerPage(s: this),
          _AnalyticsPage(s: this),
          _tier == SubscriptionTier.pro
              ? _BluetoothPage(s: this)
              : _ProLockPage(
                  onUnlock: _showProWall, featureName: 'Bluetooth Sensör'),
          _SettingsPage(s: this),
          _DebugPage(),
        ],
      ),
      bottomNavigationBar: _BottomBar(
        current: _tab,
        isPro: _tier == SubscriptionTier.pro,
        onTap: (i) {
          setState(() => _tab = i);
          _pageCtrl.jumpToPage(i);
        },
      ),
    );
  }
}

