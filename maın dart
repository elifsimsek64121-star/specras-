class _AnalyticsPage extends StatelessWidget {
  final _ShellState state;
  const _AnalyticsPage({required this.state});

  @override
  Widget build(BuildContext context) {
    final s = state;
    final dur = s._sessStart != null
        ? DateTime.now().difference(s._sessStart!)
        : Duration.zero;
    final durStr =
        '${dur.inMinutes}:${(dur.inSeconds % 60).toString().padLeft(2, '0')}';

    double avg = 0.0, peak = 0.0;
    if (s._readings.isNotEmpty) {
      avg = s._readings.map((r) => r.signal).reduce((a, b) => a + b) /
          s._readings.length;
      peak = s._readings.map((r) => r.signal).reduce((a, b) => a > b ? a : b);
    }

    final secs = s._sessStart != null
        ? DateTime.now().difference(s._sessStart!).inSeconds
        : 0;
    final rate =
        (secs > 0) ? '${(s._totalSamples / secs).toStringAsFixed(0)}/s' : '—';

    return SafeArea(
      child: SingleChildScrollView(
        physics: const BouncingScrollPhysics(),
        padding: const EdgeInsets.fromLTRB(16, 14, 16, 100),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            const _SectionLabel('SESSION ANALYTICS', large: true),
