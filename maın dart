                            child: Text('$cartCount',
                                style: const TextStyle(
                                    color: Colors.white,
                                    fontSize: 9,
                                    fontWeight: FontWeight.w900))),
                      ),
                    ),
                ],
              ),
            );
          }),
        ),
      ),
    );
  }
}

