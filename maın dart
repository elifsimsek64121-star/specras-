class _AxisBars extends StatelessWidget {
  final _ShellState s;
  const _AxisBars({required this.s});

  @override
  Widget build(BuildContext ctx) {
    final axes = [
      ('X', s._rawX, C.red),
      ('Y', s._rawY, C.green),
      ('Z', s._rawZ, C.cyan),
    ];
    final maxMag = max(s._rawX.abs(), max(s._rawY.abs(), s._rawZ.abs()));
    final norm = maxMag > 0 ? maxMag * 1.2 : 200;

    return Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
      const Text('AXIS COMPONENTS',
          style: TextStyle(color: C.tSec, fontSize: 9.5, letterSpacing: 2)),
      const SizedBox(height: 8),
      Container(
        padding: const EdgeInsets.all(14),
        decoration: BoxDecoration(
          color: C.card,
          borderRadius: BorderRadius.circular(14),
          border: Border.all(color: C.border),
        ),
        child: Column(
          children: axes.map((ax) {
            final (lbl, val, col) = ax;
            final pct = (val.abs() / norm).clamp(0.0, 1.0);
            return Padding(
              padding: const EdgeInsets.only(bottom: 10),
              child: Row(children: [
