class _Shell extends StatefulWidget {
  const _Shell();
  @override
  State<_Shell> createState() => _ShellState();
}

class _ShellState extends State<_Shell>
    with TickerProviderStateMixin, WidgetsBindingObserver {
  // ── Navigation
  int _tab = 0;
  late PageController _pc;

  // ── IAP
  Tier _tier = Tier.free;
  bool _iapReady = false;
  bool _iapBuying = false;
  final _iap = InAppPurchase.instance;
  StreamSubscription<List<PurchaseDetails>>? _iapSub;
  Map<String, ProductDetails> _products = {};

  // ── Rewarded PRO timer
  Timer? _rewardedProTimer;
  DateTime? _rewardedProExpiry;

  // ── DSP
  static const int _HIST = 300;
  static const double _EMA_F = 0.15;
  static const double _EMA_S = 0.04;
  static const double _JUMP = 25.0;

  // ── Sensor
  double _rawX = 0, _rawY = 0, _rawZ = 0, _rawMag = 0;
  double _emaFast = 50, _emaSlow = 50, _prevRaw = 50;
  final _calBuf = <double>[];
  double _baseline = 50, _noiseFloor = 1.5;
  bool _caling = false, _calDone = false;
  int _calPct = 0;
  String _calMsg = 'Waiting for sensor…';

  double _signal = 0;
  double _mMin = 9999, _mMax = 0;
  bool _monitoring = false;

  final List<double> _hist = List<double>.filled(_HIST, 0.0);
  int _hIdx = 0;

  // ── Detection
  bool _det = false;
  String _detType = 'none';
  double _detConf = 0;
  int _totalDet = 0;
  final _detections = <DetectionEvent>[];
  final _readings = <MagReading>[];

  // ── Settings
  double _sens = 6.0;
  double _alertT = 20.0;
  double _strongT = 55.0;
  double _audioVol = 0.85;
  bool _sndOn = true;
  bool _vibOn = true;
  bool _autoC = true;

  // ── Audio
  final _audio = AudioPlayer();
  bool _beeping = false;
  DateTime? _lastBUpd;

  // ── Animations
  late AnimationController _pulseCtrl, _scanCtrl, _rippleCtrl;
  late Animation<double> _pulseAnim, _scanAnim, _rippleAnim;

  // ── Misc
  DateTime? _sessStart;
  int _totalSamples = 0;
  Timer? _uiTimer;
  bool _ready = false;
  late SharedPreferences _prefs;
  StreamSubscription<MagnetometerEvent>? _magSub;

  // ── Computed
  bool get _isPro => _tier != Tier.free;

  // Remaining rewarded seconds for display
  int get _rewardedSecsLeft {
    if (_tier != Tier.rewarded || _rewardedProExpiry == null) return 0;
    final rem = _rewardedProExpiry!.difference(DateTime.now()).inSeconds;
    return rem < 0 ? 0 : rem;
  }

  // ── Navigation helper
  void navigateTo(int index) {
    if (!mounted) return;
    setState(() => _tab = index);
    _pc.jumpToPage(index);
  }

  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addObserver(this);
    _pc = PageController();
    _setupAnims();
    _boot();
  }

  @override
  void didChangeAppLifecycleState(AppLifecycleState state) {
    if (state == AppLifecycleState.paused) _magSub?.pause();
    if (state == AppLifecycleState.resumed) _magSub?.resume();
  }

  // ── Boot
  Future<void> _boot() async {
    Log.i('╔══════════════════════════════╗');
    Log.i('║   SPECTRA PRO v5.0 BOOT     ║');
    Log.i('╚══════════════════════════════╝');

    _prefs = await SharedPreferences.getInstance();
    _loadPrefs();

    // IAP
    _iapSub = _iap.purchaseStream.listen(_onPurchase);
    _iapReady = await _iap.isAvailable();
    if (_iapReady) {
      Log.i('IAP available');
      await _loadProducts();
      await _iap.restorePurchases();
    } else {
      Log.i('IAP unavailable');
    }

    // Audio
    try {
      await _audio.setAsset('assets/beep.mp3');
      await _audio.setLoopMode(LoopMode.one);
      await _audio.setVolume(0.0);
      Log.i('Audio system ready');
    } catch (e) {
      Log.i('Audio error: $e');
    }

    // Ads
    if (!_isPro) {
      adManager.loadBanner();
      adManager.loadInterstitial();
      adManager.loadRewarded();
    }

    _sessStart = DateTime.now();
    _startMagnetometer();

    if (mounted) setState(() => _ready = true);
    if (mounted && _autoC) await _runCalibration();

    Log.i('╔══════════════════════════════╗');
    Log.i('║     BOOT SUCCESS ✅          ║');
    Log.i('╚══════════════════════════════╝');
  }

  // ── Prefs
  void _loadPrefs() {
    _sndOn = _prefs.getBool('snd') ?? true;
    _vibOn = _prefs.getBool('vib') ?? true;
    _autoC = _prefs.getBool('autoc') ?? true;
    _sens = _prefs.getDouble('sens') ?? 6.0;
    _alertT = _prefs.getDouble('alt') ?? 20.0;
    _strongT = _prefs.getDouble('str') ?? 55.0;
    _audioVol = _prefs.getDouble('audVol') ?? 0.85;
    final ts = _prefs.getString('tier') ?? 'free';
    // Never persist rewarded tier across sessions
    _tier = Tier.values.firstWhere(
      (t) => t.name == ts && t != Tier.rewarded,
      orElse: () => Tier.free,
    );
    Log.i('Preferences loaded: tier=${_tier.name}');
  }

  void _savePrefs() {
    _prefs
      ..setBool('snd', _sndOn)
      ..setBool('vib', _vibOn)
      ..setBool('autoc', _autoC)
      ..setDouble('sens', _sens)
      ..setDouble('alt', _alertT)
      ..setDouble('str', _strongT)
      ..setDouble('audVol', _audioVol)
      ..setString('tier', _tier == Tier.rewarded ? 'free' : _tier.name);
  }

  // ── Rewarded PRO (2 minutes)
  void _activateRewardedPro() {
    _rewardedProTimer?.cancel();
    const dur = Duration(minutes: 2);
    setState(() {
      _tier = Tier.rewarded;
      _rewardedProExpiry = DateTime.now().add(dur);
    });
    Log.i('Rewarded PRO activated — 2 min');
    _snack('🎉 2-Minute PRO unlocked! Enjoy all features.', C.green);

    _rewardedProTimer = Timer.periodic(const Duration(seconds: 1), (t) {
      if (!mounted) {
        t.cancel();
        return;
      }
      final rem = _rewardedProExpiry!.difference(DateTime.now());
      if (rem.isNegative) {
        t.cancel();
        _expireRewardedPro();
      } else {
        setState(() {}); // refresh countdown
      }
    });
  }

  void _expireRewardedPro() {
    if (!mounted) return;
    setState(() {
      _tier = Tier.free;
      _rewardedProExpiry = null;
    });
    // Reload ads
    adManager.loadBanner();
    adManager.loadInterstitial();
    adManager.loadRewarded();
    _snack('PRO trial ended. Watch another ad or subscribe!', C.orange);
    Log.i('Rewarded PRO expired');
  }

  void _watchRewardedAd() {
    if (adManager.rewardedAd == null) {
      adManager.loadRewarded();
      _snack('Ad loading… please try again in a moment.', C.tSec);
      return;
    }
    adManager.showRewarded(_activateRewardedPro);
  }

  // ── IAP
  Future<void> _loadProducts() async {
    try {
      final res = await _iap.queryProductDetails(IAPIds.all);
      if (res.notFoundIDs.isNotEmpty) {
        Log.i('Missing products: ${res.notFoundIDs}');
      }
      if (mounted) {
        setState(() {
          for (final p in res.productDetails) {
            _products[p.id] = p;
            Log.i('Product: ${p.id} — ${p.price}');
          }
        });
      }
    } catch (e) {
      Log.i('Product load error: $e');
    }
  }

  void _onPurchase(List<PurchaseDetails> purchases) async {
    for (final p in purchases) {
      Log.i('Purchase: ${p.status} — ${p.productID}');
      if (p.status == PurchaseStatus.purchased ||
          p.status == PurchaseStatus.restored) {
        _grantPro(p.productID);
        if (p.pendingCompletePurchase) {
          try {
            await _iap.completePurchase(p);
          } catch (e) {
            Log.i('completePurchase error: $e');
          }
        }
      } else if (p.status == PurchaseStatus.error) {
        Log.i('Purchase error: ${p.error?.message}');
        if (mounted) setState(() => _iapBuying = false);
        _snack('Purchase failed. Please try again.', C.red);
      } else if (p.status == PurchaseStatus.canceled) {
        if (mounted) setState(() => _iapBuying = false);
      }
    }
  }

  void _grantPro(String productId) {
    if (!mounted) return;
    Tier t = Tier.free;
    if (productId == IAPIds.proMonthly) t = Tier.monthly;
    if (productId == IAPIds.proAnnual) t = Tier.annual;
    if (productId == IAPIds.proLifetime) t = Tier.lifetime;
    if (t == Tier.free) return;

    _rewardedProTimer?.cancel();
    setState(() {
      _tier = t;
      _iapBuying = false;
    });
    _prefs.setString('tier', t.name);
    adManager.disposeAll();
    context.read<ShoppingCart>().clear();
    _snack('🎉 PRO ACTIVE! All features unlocked.', C.green);
    Log.i('PRO granted: $t');
  }

  void _buyProduct(ProductDetails p) {
    if (!_iapReady) {
      _snack('Purchase system unavailable', C.red);
      return;
    }
    setState(() => _iapBuying = true);
    _iap
        .buyNonConsumable(purchaseParam: PurchaseParam(productDetails: p))
        .catchError((e) {
      Log.i('buyNonConsumable error: $e');
      if (mounted) setState(() => _iapBuying = false);
      _snack('Purchase failed to start: $e', C.red);
    });
    Log.i('Purchase started: ${p.id}');
  }

  void showCart() {
    showModalBottomSheet(
      context: context,
      isScrollControlled: true,
      backgroundColor: C.surface,
      shape: const RoundedRectangleBorder(
        borderRadius: BorderRadius.vertical(top: Radius.circular(28)),
      ),
      builder: (_) => _CartSheet(
        products: _products,
        onCheckout: _processCheckout,
      ),
    );
  }

  void _processCheckout() {
    final cart = context.read<ShoppingCart>();
    if (cart.items.isEmpty) {
      _snack('Cart is empty', C.red);
      return;
    }
    final product = _products[cart.items.first.id];
    if (product != null) {
      _buyProduct(product);
    } else {
      _snack('Product not found — check internet connection', C.red);
    }
  }

  // ── Animations
  void _setupAnims() {
    _pulseCtrl = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 1500),
    )..repeat(reverse: true);
    _pulseAnim = Tween(begin: 0.93, end: 1.07).animate(
      CurvedAnimation(parent: _pulseCtrl, curve: Curves.easeInOutSine),
    );

    _scanCtrl = AnimationController(
      vsync: this,
      duration: const Duration(seconds: 3),
    )..repeat();
    _scanAnim = Tween(begin: 0.0, end: 1.0).animate(
      CurvedAnimation(parent: _scanCtrl, curve: Curves.linear),
    );

    _rippleCtrl = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 1000),
    )..repeat(reverse: true);
    _rippleAnim = Tween(begin: 0.3, end: 1.0).animate(
      CurvedAnimation(parent: _rippleCtrl, curve: Curves.easeInOut),
    );
  }

  // ── Magnetometer
  void _startMagnetometer() {
    _magSub?.cancel();
    _magSub = magnetometerEventStream(
      samplingPeriod: SensorInterval.uiInterval,
    ).listen(_onMagEvent, onError: (e) => Log.i('Magnetometer error: $e'));
    Log.i('Magnetometer started');
  }

  void _onMagEvent(MagnetometerEvent e) {
    _rawX = e.x;
    _rawY = e.y;
    _rawZ = e.z;
    _rawMag = sqrt(e.x * e.x + e.y * e.y + e.z * e.z);
    _totalSamples++;

    final diff = (_rawMag - _prevRaw).abs();
    final w = diff > _JUMP ? 0.03 : _EMA_F;
    _emaFast = w * _rawMag + (1 - w) * _emaFast;
    _prevRaw = _rawMag;

    if (_caling) _calBuf.add(_rawMag);

    if (_calDone && _monitoring) {
      if (_signal < _alertT * 0.5) {
        _emaSlow = _EMA_S * _rawMag + (1 - _EMA_S) * _emaSlow;
      }
      final dev = (_emaFast - _baseline).abs();
      _signal = (dev / _noiseFloor * _sens * 1.2).clamp(0.0, 100.0);

      if (_emaFast < _mMin) _mMin = _emaFast;
      if (_emaFast > _mMax) _mMax = _emaFast;

      _hist[_hIdx] = _emaFast;
      _hIdx = (_hIdx + 1) % _HIST;

      _readings.add(MagReading(
        ts: DateTime.now(),
        x: _rawX,
        y: _rawY,
        z: _rawZ,
        raw: _rawMag,
        signal: _signal,
      ));
      if (_readings.length > 5000) _readings.removeAt(0);

      _classify();
      _feedback();
    }
    _schedUI();
  }

  // ── Calibration
  Future<void> _runCalibration() async {
    if (_caling) return;
    if (mounted) {
      setState(() {
        _caling = true;
        _calDone = false;
        _calPct = 0;
        _calMsg = 'Hold device still…';
        _monitoring = false;
        _det = false;
        _signal = 0;
        _calBuf.clear();
        _hist.fillRange(0, _HIST, 0.0);
        _hIdx = 0;
        _mMin = 9999;
        _mMax = 0;
      });
    }
    try {
      await _audio.stop();
    } catch (_) {}

    for (int i = 0; i < 10; i++) {
      await Future.delayed(const Duration(seconds: 1));
      if (mounted) setState(() => _calPct = (i + 1) * 10);
    }

    _computeBaseline();
    if (mounted) {
      setState(() {
        _caling = false;
        _calDone = true;
        _monitoring = true;
        _calMsg = 'Calibrated — Active scanning';
      });
    }
  }

  void _computeBaseline() {
    if (_calBuf.isEmpty) {
      _baseline = _rawMag.isFinite ? _rawMag : 50;
      _noiseFloor = 2.0;
    } else {
      _baseline = _calBuf.reduce((a, b) => a + b) / _calBuf.length;
      _noiseFloor = 1.5;
    }
    _emaFast = _emaSlow = _baseline;
    _mMin = _baseline;
    _mMax = _baseline;
    _calBuf.clear();
    Log.i('Baseline: ${_baseline.toStringAsFixed(3)} µT');
  }

  // ── Classification
  void _classify() {
    if (_signal > _alertT) {
      final isStrong = _signal > _strongT;
      _detType = isStrong ? 'ferrous' : 'nonferrous';
      _detConf = isStrong ? 0.88 : 0.74;
      if (!_det) {
        _det = true;
        _totalDet++;
        _detections.add(DetectionEvent(
          ts: DateTime.now(),
          type: _detType,
          conf: _detConf,
          signal: _signal,
          label: isStrong ? 'FERROUS / STEEL' : 'NON-FERROUS METAL',
          color: isStrong ? C.red : C.orange,
          icon: isStrong
              ? Icons.bolt_rounded
              : Icons.radio_button_checked_rounded,
        ));
        Log.i('Detection: $_detType @ ${_signal.toStringAsFixed(1)}');
      }
    } else if (_det) {
      _det = false;
      _detType = 'none';
    }
  }

  // ── Audio/Vibration Feedback
  void _feedback() {
    if (_signal > _alertT) {
      if (_sndOn) {
        final spd = (0.5 + (_signal / 100) * 2.2).clamp(0.5, 2.7);
        if (!_beeping) {
          _audio.play().catchError((_) {});
          _audio.setVolume(_audioVol).catchError((_) {});
          _beeping = true;
        }
        final now = DateTime.now();
        if (_lastBUpd == null ||
            now.difference(_lastBUpd!).inMilliseconds > 80) {
          _audio.setSpeed(spd).catchError((_) {});
          _lastBUpd = now;
        }
      }
      if (_vibOn) {
        try {
          Vibration.vibrate(
            duration: (_signal > _strongT) ? 250 : 120,
            amplitude: 180,
          );
        } catch (_) {}
      }
    } else if (_beeping) {
      _audio.stop().catchError((_) {});
      _audio.setVolume(0.0).catchError((_) {});
      _beeping = false;
    }
  }

  void _schedUI() {
    _uiTimer?.cancel();
    _uiTimer = Timer(const Duration(milliseconds: 55), () {
      if (mounted) setState(() {});
    });
  }

  void _snack(String msg, Color bg) {
    if (!mounted) return;
    ScaffoldMessenger.of(context).clearSnackBars();
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(msg,
            style: const TextStyle(
                fontWeight: FontWeight.w700, color: Colors.white)),
        backgroundColor: bg,
        behavior: SnackBarBehavior.floating,
        margin: const EdgeInsets.all(12),
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
      ),
    );
  }

  @override
  void dispose() {
    WidgetsBinding.instance.removeObserver(this);
    _magSub?.cancel();
    _iapSub?.cancel();
    _uiTimer?.cancel();
    _rewardedProTimer?.cancel();
    _audio.dispose();
    _pulseCtrl.dispose();
    _scanCtrl.dispose();
    _rippleCtrl.dispose();
    _pc.dispose();
    adManager.disposeAll();
    super.dispose();
  }

  // ── Build
  @override
