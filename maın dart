class _DebugPage extends StatefulWidget {
  @override
  State<_DebugPage> createState() => _DebugPageState();
}

class _DebugPageState extends State<_DebugPage> {
  @override
  Widget build(BuildContext context) {
    final logs = AppLog.all;
    return SafeArea(
      child: Column(children: [
        const Padding(
          padding: EdgeInsets.fromLTRB(16, 8, 16, 8),
          child: _PageTitle(title: 'DEBUG KONSOLU'),
        ),
        Padding(
          padding: const EdgeInsets.symmetric(horizontal: 16),
          child: Row(children: [
            Expanded(
                child: _DebugBtn(
              label: 'Temizle',
              icon: Icons.delete_rounded,
              color: AppColors.red,
              onTap: () {
                AppLog.clear();
                setState(() {});
              },
            )),
            const SizedBox(width: 10),
            Expanded(
                child: _DebugBtn(
              label: 'Yenile',
              icon: Icons.refresh_rounded,
              color: AppColors.cyan,
              onTap: () => setState(() {}),
            )),
          ]),
        ),
        const SizedBox(height: 8),
        Expanded(
          child: logs.isEmpty
              ? const Center(
                  child: Text('Log yok',
                      style: TextStyle(color: AppColors.textDim)))
              : ListView.builder(
                  reverse: true,
                  padding: const EdgeInsets.fromLTRB(16, 0, 16, 16),
                  itemCount: logs.length,
                  itemBuilder: (_, i) {
                    final log = logs[logs.length - 1 - i];
                    Color col = AppColors.textSec;
                    if (log.contains('❌'))
                      col = AppColors.red;
                    else if (log.contains('✅'))
                      col = AppColors.green;
                    else if (log.contains('🔴'))
                      col = AppColors.orange;
                    else if (log.contains('🔵'))
                      col = AppColors.cyan;
                    else if (log.contains('⚠️')) col = AppColors.orange;
                    return Text(
                      log,
                      style: TextStyle(
                        fontSize: 10,
                        color: col,
                        fontFamily: AppText.mono,
                        height: 1.5,
                      ),
                    );
                  },
                ),
        ),
      ]),
    );
  }
}

